#!/usr/bin/env node

const https = require('https');
const path = require('path');
const { version } = require('../package.json');
const { sendText, listenForFinalAnswer } = require('../lib/opencode');
const { listServers, activateServer } = require('../lib/ocmux');

// ---------------------------------------------------------------------------
// Telegram Bot API helpers
// ---------------------------------------------------------------------------

function telegramRequest(token, method, params) {
  return new Promise((resolve, reject) => {
    const body = JSON.stringify(params || {});
    const options = {
      hostname: 'api.telegram.org',
      port: 443,
      path: `/bot${token}/${method}`,
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Content-Length': Buffer.byteLength(body),
      },
    };
    const req = https.request(options, (res) => {
      let data = '';
      res.on('data', (chunk) => { data += chunk; });
      res.on('end', () => {
        try {
          resolve(JSON.parse(data));
        } catch (e) {
          reject(new Error(`Failed to parse Telegram response: ${data}`));
        }
      });
    });
    req.on('error', reject);
    req.write(body);
    req.end();
  });
}

function getUpdates(token, offset, timeout) {
  return telegramRequest(token, 'getUpdates', {
    offset,
    timeout: timeout != null ? timeout : 30,
    allowed_updates: ['message'],
  });
}

function sendTelegramMessage(token, chatId, text, parseMode) {
  const params = { chat_id: chatId, text };
  if (parseMode) params.parse_mode = parseMode;
  return telegramRequest(token, 'sendMessage', params);
}

// Lightweight Markdown to Telegram HTML conversion.
function convertMarkdownToHtml(text) {
  const parts = text.split('```');

  return parts.map((part, i) => {
    if (i % 2 === 1) {
      // Code block — strip language tag, escape entities, wrap in <pre>
      const nl = part.indexOf('\n');
      const inner = nl >= 0 ? part.slice(nl + 1) : part;
      return '<pre>' + inner
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;') + '</pre>';
    }

    // Text segment

    // Phase 1: extract table blocks into placeholders
    const placeholders = [];
    let processed = '';
    const lines = part.split('\n');
    let li = 0;
    while (li < lines.length) {
      if (/^\|/.test(lines[li])) {
        const table = [];
        while (li < lines.length && /^\|/.test(lines[li])) {
          table.push(lines[li]);
          li++;
        }
        const hasSep = table.some(l => /^\|[-:| ]+\|$/.test(l));
        if (table.length >= 2 && hasSep) {
          const cleaned = table
            .map(l => l.replace(/^\|/, '').replace(/\|$/, ''))
            .filter(l => !/^\s*[|:\- ]+\s*$/.test(l));
          if (cleaned.length > 0) {
            const escaped = cleaned.map(l =>
              l.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
            );
            const idx = placeholders.length;
            placeholders.push('<pre>' + escaped.join('\n') + '</pre>');
            processed += '\0T' + idx + '\0\n';
            continue;
          }
        }
        for (const l of table) { processed += l + '\n'; }
      } else {
        processed += lines[li] + '\n';
        li++;
      }
    }

    // Phase 2: escape entities and apply markdown on non-table text
    let html = processed
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;');
    html = html.replace(/`([^`]+)`/g, '<code>$1</code>');
    html = html.replace(/^#{1,6}\s+(.+)$/gm, '<b>$1</b>');
    html = html.replace(/^\s*-{3,}\s*$/gm, '────────────────────');
    html = html.replace(/\*\*(.+?)\*\*/g, '<b>$1</b>');
    html = html.replace(/\*(.+?)\*/g, '<i>$1</i>');

    // Phase 3: restore table placeholders
    for (let j = 0; j < placeholders.length; j++) {
      html = html.split('\0T' + j + '\0').join(placeholders[j]);
    }

    return html;
  }).join('');
}

// Parse TGAGENTP_ALLOWED_CHAT_IDS env var (comma-separated chat IDs).
// Returns null when unset (all chats allowed), or an array of IDs to filter.
function parseAllowlist(raw) {
  if (!raw || !raw.trim()) return null;
  const ids = raw.split(',').map(s => s.trim()).filter(Boolean);
  return ids.length > 0 ? ids : null;
}

// Split text into chunks of at most maxLength characters,
// breaking at newlines when possible.
function splitMessage(text, maxLength = 4096) {
  if (text.length <= maxLength) return [text];
  const chunks = [];
  let start = 0;
  while (start < text.length) {
    let end = Math.min(start + maxLength, text.length);
    if (end < text.length) {
      const newlinePos = text.lastIndexOf('\n', end);
      if (newlinePos > start) {
        end = newlinePos + 1;
      }
    }
    chunks.push(text.slice(start, end));
    start = end;
  }
  return chunks;
}

// Send a text message to a Telegram chat, splitting into multiple
// messages if it exceeds the 4096-character limit.
// Converts Markdown to Telegram HTML formatting.
// Splits the raw text first, then converts each chunk independently
// to avoid broken HTML tags across messages.
async function sendLongMessage(token, chatId, text) {
  const chunks = splitMessage(text);
  for (const chunk of chunks) {
    const html = convertMarkdownToHtml(chunk);
    await sendTelegramMessage(token, chatId, html, 'HTML');
  }
}

// ---------------------------------------------------------------------------
// Telegram command handlers
// ---------------------------------------------------------------------------

async function cmdHelp(token, chatId, args) {
  if (args.length > 0) {
    const topic = args[0].toLowerCase();
    if (topic === 'servers') {
      await sendLongMessage(token, chatId,
        '`/servers` — list all opencode servers (ocmux sessions)\n' +
        '`/servers switch <name>` — switch target server\n\n' +
        '`<name>` can be a full path or basename of the project directory.');
      return;
    }
    await sendLongMessage(token, chatId,
      'Unknown topic. Try `/help servers` or just `/help`.');
    return;
  }
  await sendLongMessage(token, chatId,
    '`/help` — show this message\n' +
    '`/help <topic>` — detailed help\n' +
    '`/servers` — list running opencode servers\n' +
    '`/servers switch <name>` — switch to a different server\n\n' +
    'Everything else is forwarded to the active server as `[Telegram] <text>`.');
}

async function cmdServers(token, chatId, args, setServer) {
  if (args.length > 0 && args[0] === 'switch') {
    if (args.length < 2) {
      await sendLongMessage(token, chatId,
        'Usage: `/servers switch <name>`\n' +
        '`<name>` can be a full directory path or a basename.');
      return;
    }
    const name = args.slice(1).join(' ');
    const servers = listServers();
    if (servers.length === 0) {
      await sendLongMessage(token, chatId, 'No servers running.');
      return;
    }
    let matches = servers.filter(s => s.dir === name);
    if (matches.length === 0) {
      matches = servers.filter(s => path.basename(s.dir) === name);
    }
    if (matches.length === 0) {
      matches = servers.filter(s => s.dir.includes(name) || path.basename(s.dir).includes(name));
    }
    if (matches.length === 0) {
      await sendLongMessage(token, chatId, `No server found matching "${name}".`);
      return;
    }
    if (matches.length > 1) {
      const list = matches.map(s => `  ${s.url} → ${s.dir}`).join('\n');
      await sendLongMessage(token, chatId,
        `Multiple matches for "${name}":\n${list}\n\nPlease be more specific.`);
      return;
    }
    const target = matches[0];
    setServer(target.url);
    activateServer(target.dir, target.index, target.url);
    await sendLongMessage(token, chatId,
      `Switched to server: ${target.url} → ${target.dir}`);
    return;
  }

  // Default: list servers
  const servers = listServers();
  if (servers.length === 0) {
    await sendLongMessage(token, chatId, 'No servers running.');
    return;
  }
  const lines = servers.map(s => `  ${s.url} → ${s.dir} (${s.status})`);
  await sendLongMessage(token, chatId, 'Active servers:\n' + lines.join('\n'));
}

const COMMANDS = {
  'help': cmdHelp,
  'servers': cmdServers,
};

// --------------------------------------------------------------------------
// Main
// ---------------------------------------------------------------------------

async function main() {
  let serverBase = 'http://localhost:4096';

  const args = process.argv.slice(2);
  for (let i = 0; i < args.length; i++) {
    if (args[i] === '--version') {
      console.log(version);
      process.exit(0);
    } else if (args[i] === '--help') {
      console.error('Usage: tgagentp [options] [url]');
      console.error('');
      console.error('Bridge a Telegram bot chat with an OpenCode TUI session.');
      console.error('Incoming Telegram messages are forwarded to OpenCode; answers are sent back to the chat.');
      console.error('');
      console.error('Options:');
      console.error('  --version  Show version');
      console.error('  --help     Show this help message');
      console.error('');
      console.error('Arguments:');
      console.error('  url        OpenCode TUI server URL or port number (default: 4096)');
      console.error('             Examples: 4096, http://localhost:4096, http://192.168.1.50:4096');
      console.error('');
      console.error('Environment variables:');
      console.error('  TELEGRAM_BOT_TOKEN         Telegram bot token (required)');
      console.error('  OPENCODE_SERVER_PASSWORD    OpenCode server password (optional)');
      console.error('  OPENCODE_SERVER_USERNAME    OpenCode server username (optional, default: opencode)');
      console.error('  TGAGENTP_ALLOWED_CHAT_IDS   Comma-separated Telegram chat IDs (optional)');
      console.error('                               Example: "123456,-789012"');
      console.error('');
      console.error('See also: agentp, ocmux');
      console.error('');
      console.error('Examples:');
      console.error('  export TELEGRAM_BOT_TOKEN="your-bot-token"');
      console.error('  tgagentp');
      console.error('  tgagentp 4096');
      console.error('  tgagentp http://192.168.1.50:4096');
      process.exit(0);
    } else if (args[i].includes('://')) {
      serverBase = args[i].replace(/\/+$/, '');
    } else if (/^\d+$/.test(args[i])) {
      serverBase = 'http://localhost:' + args[i];
    }
  }

  const token = process.env.TELEGRAM_BOT_TOKEN;
  if (!token) {
    console.error('Error: TELEGRAM_BOT_TOKEN environment variable is not set.');
    console.error('Create a bot with @BotFather on Telegram and export the token before running tgagentp.');
    process.exit(1);
  }

  process.stderr.write(`tgagentp v${version} started. OpenCode server: ${serverBase}\n`);

  if (!process.env.OPENCODE_SERVER_PASSWORD) {
    process.stderr.write('🔓 ⚠️  Server is not password-protected! Set OPENCODE_SERVER_PASSWORD for better security.\n');
  }

  const allowedChatIds = parseAllowlist(process.env.TGAGENTP_ALLOWED_CHAT_IDS);
  if (allowedChatIds) {
    process.stderr.write(`Chat allowlist: ${allowedChatIds.length} chat(s) configured\n`);
  } else {
    process.stderr.write('Chat allowlist: not configured (all chats accepted)\n');
  }

  process.stderr.write('Waiting for Telegram messages... (Ctrl+C to stop)\n');

  const setServer = (url) => {
    serverBase = url;
    process.stderr.write(`Switched to server: ${url}\n`);
  };

  let offset = 0;

  // Poll for updates and forward each text message to OpenCode, sending the answer back.
  while (true) {
    let result;
    try {
      result = await getUpdates(token, offset, 30);
    } catch (err) {
      process.stderr.write(`Polling error: ${err.message}\n`);
      await new Promise((r) => setTimeout(r, 5000));
      continue;
    }

    if (!result.ok) {
      process.stderr.write(`Telegram API error: ${result.description || JSON.stringify(result)}\n`);
      await new Promise((r) => setTimeout(r, 5000));
      continue;
    }

    for (const update of result.result) {
      offset = update.update_id + 1;

      const msg = update.message;
      if (!msg || typeof msg.text !== 'string') {
        // Ignore non-text messages (photos, stickers, etc.)
        continue;
      }

      const chatId = String(msg.chat.id);
      const text = msg.text;
      const from = msg.from?.username
        ? `@${msg.from.username}`
        : [msg.from?.first_name, msg.from?.last_name].filter(Boolean).join(' ') || 'unknown';

      // Enforce chat allowlist if configured
      if (allowedChatIds && !allowedChatIds.includes(chatId)) {
        process.stderr.write(`[chat ${chatId}] ${from}: blocked (not in allowlist)\n`);
        continue;
      }

      process.stderr.write(`[chat ${chatId}] ${from}: ${text}\n`);

      // Intercept /commands
      if (text.startsWith('/')) {
        const parts = text.slice(1).split(' ');
        const cmd = parts[0].toLowerCase();
        const cmdArgs = parts.slice(1);
        const handler = COMMANDS[cmd];
        if (handler) {
          try {
            await handler(token, chatId, cmdArgs, setServer);
          } catch (err) {
            process.stderr.write(`Error handling /${cmd}: ${err.message}\n`);
            try { await sendLongMessage(token, chatId, `Error: ${err.message}`); } catch (_) {}
          }
        } else {
          await sendLongMessage(token, chatId,
            `Unknown command: /${cmd}\n\nAvailable commands: /help, /servers`);
        }
        continue;
      }

      try {
        await sendText(serverBase, `[Telegram] ${text}`);
        const answer = await listenForFinalAnswer(serverBase);
        if (answer.trim()) {
          await sendLongMessage(token, chatId, answer.trim());
        }
      } catch (err) {
        process.stderr.write(`Error processing message: ${err.message}\n`);
        try {
          await sendLongMessage(token, chatId, `Error: ${err.message}`);
        } catch (_) {}
      }
    }
  }
}

process.on('SIGINT', () => {
  process.stderr.write('\ntgagentp stopped.\n');
  process.exit(0);
});

main().catch((err) => {
  console.error('Error:', err.message);
  process.exit(1);
});
