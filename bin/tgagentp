#!/usr/bin/env node

const http = require('http');
const fs = require('fs');
const path = require('path');
const { version } = require('../package.json');
const { getAuthHeaders, makeRequest, buildJsonRequest, sendText, listenForFinalAnswer, listSessions, createSession, updateSession, selectSession, sendToSession, sendToSessionAsync, respondToPermission, respondToQuestion, listenForSessionEvents, listAgents, listProviders, isServerAlive } = require('../lib/opencode.js');

// Logger: info→stdout, error→stderr (always), debug→stderr (--verbose only)
const log = {
  verbose: false,
  info(msg) { process.stdout.write(`${new Date().toISOString().replace('T', ' ').replace(/\.\d{3}Z$/, '')} ${msg}\n`); },
  error(msg) { process.stderr.write(`${msg}\n`); },
  debug(msg) { if (this.verbose) process.stderr.write(`${msg}\n`); },
};

const TGAGENTP_PORT = parseInt(process.env.TGAGENTP_PORT || '0', 10);
const PORT_FILE = '/tmp/tgagentp-port';
const TGAGENTP_DEBOUNCE_MS = parseInt(process.env.TGAGENTP_DEBOUNCE_MS || '5000', 10);
const CONNECTIONS_FILE = '/tmp/tgagentp-connections.json';
const { listServers, activateServer, resurrectServer, statefileFor, readState, tuiPaneId, serverStatus, listDeadServers } = require('../lib/ocmux.js');
const { executeTuiCommand } = require('../lib/tui-cmd.js');
const { getUpdates, downloadTelegramFile, sendTelegramDocument } = require('../lib/telegram-api.js');
const { sendLongMessage } = require('../lib/telegram-format.js');
const { spawnSync } = require('child_process');

const TGAGENTP_ROOT = process.env.TGAGENTP_ROOT;
let tgagentpRootValid = false;
if (TGAGENTP_ROOT) {
  try {
    const stats = fs.statSync(TGAGENTP_ROOT);
    if (!stats.isDirectory()) {
      log.error(`TGAGENTP_ROOT is not a directory: ${TGAGENTP_ROOT} — /serve and /new disabled`);
    } else {
      try {
        fs.accessSync(TGAGENTP_ROOT, fs.constants.W_OK);
        tgagentpRootValid = true;
      } catch {
        log.error(`TGAGENTP_ROOT is not writable: ${TGAGENTP_ROOT} — /serve and /new disabled`);
      }
    }
  } catch {
    log.error(`TGAGENTP_ROOT does not exist: ${TGAGENTP_ROOT} — /serve and /new disabled`);
  }
}

// Persist chat↔server directory mappings across restarts
function saveConnection(chatId, threadId, dir) {
  let data = { connections: [] };
  try { data = JSON.parse(fs.readFileSync(CONNECTIONS_FILE, 'utf8')); } catch {}
  const key = convKey(chatId, threadId);
  const idx = data.connections.findIndex(c => convKey(c.chatId, c.threadId) === key);
  const entry = { chatId, threadId: threadId || null, dir };
  if (idx !== -1) data.connections[idx] = entry;
  else data.connections.push(entry);
  try { fs.writeFileSync(CONNECTIONS_FILE, JSON.stringify(data, null, 2)); } catch {}
}

function removeConnection(chatId, threadId) {
  let data = { connections: [] };
  try { data = JSON.parse(fs.readFileSync(CONNECTIONS_FILE, 'utf8')); } catch {}
  const key = convKey(chatId, threadId);
  data.connections = data.connections.filter(c => convKey(c.chatId, c.threadId) !== key);
  try { fs.writeFileSync(CONNECTIONS_FILE, JSON.stringify(data, null, 2)); } catch {}
}

function clearConnections() {
  try { fs.unlinkSync(CONNECTIONS_FILE); } catch {}
}

// Agentp gateway message queue, keyed by server URL
const agentpQueues = {};

function validateAgentpAuth(req) {
  const password = process.env.OPENCODE_SERVER_PASSWORD;
  if (!password) return true;
  const username = process.env.OPENCODE_SERVER_USERNAME || 'opencode';
  const expected = 'Basic ' + Buffer.from(`${username}:${password}`).toString('base64');
  return req.headers.authorization === expected;
}

function flushAgentpQueue(server, token, chatId, threadId) {
  if (!chatId) return;
  const q = agentpQueues[server];
  if (!q || q.messages.length === 0) return;
  const msgs = q.messages.splice(0);
  q.notified = false;
  if (q.notifyTimer) { clearTimeout(q.notifyTimer); q.notifyTimer = null; }
  const cs = { chatId, threadId };
  sendLongMessage(token, cs,
    `📨 Delivering ${msgs.length} queued agentp message(s):`, undefined, threadId)
    .then(() => {
      for (const msg of msgs) {
        sendLongMessage(token, cs, msg.trim(), undefined, threadId).catch(() => {});
      }
    })
    .catch(() => {});
}

// Check if an opencode server is reachable by hitting its /session endpoint.
// Uses a short 5s timeout; returns true for any HTTP response (even 4xx/5xx)
// and false only for connection-level failures (dead server, DNS, timeout).
// ---------------------------------------------------------------------------
// Per-chat state
// ---------------------------------------------------------------------------

const MAX_RECORDED_MSGS = 100;
const MAX_RECORDED_BYTES = 100 * 1024;

const chatStates = {};
const serverOwners = {}; // serverUrl → { chatId, threadId } (for agentp gateway routing)

// Compound key for isolated chat+thread (forum topic) state
function convKey(chatId, threadId) {
  return threadId ? `${chatId}:t${threadId}` : chatId;
}

function getChatState(chatId, threadId, defaultServer) {
  const key = convKey(chatId, threadId);
  if (!chatStates[key]) {
    chatStates[key] = {
      chatId,
      threadId: threadId || null,
      serverBase: defaultServer || null,
      recording: { active: false, paused: false, messages: [], bytes: 0 },
      ring: { messages: [], bytes: 0 },
    };
  }
  return chatStates[key];
}

const RING_MAX_MSGS = 50;
const RING_MAX_BYTES = 50 * 1024;

function bufferMessage(chatId, threadId, role, text) {
  const cs = getChatState(chatId, threadId);

  // Always maintain an in-memory ring buffer of recent messages.
  // This enables retroactive /record N: copy last N messages into recording.
  cs.ring.messages.push({ role, text });
  cs.ring.bytes += Buffer.byteLength(text, 'utf8');
  while (cs.ring.messages.length > RING_MAX_MSGS || cs.ring.bytes > RING_MAX_BYTES) {
    const oldest = cs.ring.messages.shift();
    cs.ring.bytes -= Buffer.byteLength(oldest.text, 'utf8');
  }

  // Recording buffer (only when active AND not paused)
  if (!cs.recording.active || cs.recording.paused) return;
  cs.recording.messages.push({ role, text });
  cs.recording.bytes += Buffer.byteLength(text, 'utf8');
  while (cs.recording.messages.length > MAX_RECORDED_MSGS || cs.recording.bytes > MAX_RECORDED_BYTES) {
    const oldest = cs.recording.messages.shift();
    cs.recording.bytes -= Buffer.byteLength(oldest.text, 'utf8');
  }
}

function flushRecorded(chatId, threadId) {
  const cs = getChatState(chatId, threadId);
  if (!cs.recording.active) return [];
  const msgs = cs.recording.messages.splice(0);
  cs.recording.bytes = 0;
  return msgs;
}

// Ring buffer of recent responses keyed by Telegram message ID.
// Stored per chatId+threadId for /markdown command lookups.
const responseHistory = {}; // convKey → [{ messageId, text }]

function recordResponseMessage(chatId, threadId, messageIds, text) {
  const key = convKey(chatId, threadId);
  if (!responseHistory[key]) responseHistory[key] = [];
  responseHistory[key].push({ messageIds, text });
  if (responseHistory[key].length > 20) responseHistory[key].shift();
}

function getResponseByMessageId(chatId, threadId, messageId) {
  const key = convKey(chatId, threadId);
  const list = responseHistory[key] || [];
  return list.find(e => e.messageIds.includes(messageId));
}

function getRecentResponse(chatId, threadId, index) {
  const key = convKey(chatId, threadId);
  const list = responseHistory[key] || [];
  if (list.length === 0) return null;
  // index 1 = most recent, 2 = second most recent, etc.
  const idx = list.length - (index || 1);
  if (idx < 0 || idx >= list.length) return null;
  return list[idx];
}

// ---------------------------------------------------------------------------
// Telegram Bot API helpers
// ---------------------------------------------------------------------------

// Lightweight Markdown to Telegram HTML conversion.
// Parse TGAGENTP_ALLOWED_CHAT_IDS env var (comma-separated chat IDs).
// Returns null when unset (all chats allowed), or an array of IDs to filter.
function parseAllowlist(raw) {
  if (!raw || !raw.trim()) return null;
  const ids = raw.split(',').map(s => s.trim()).filter(Boolean);
  return ids.length > 0 ? ids : null;
}

// Build a quoted reply context from a Telegram reply_to_message.
// Returns empty string if the message isn't a reply or has no text.
// Uses a dynamic code-fence length (max consecutive backticks + 1)
// so nested backticks never break the structure.
const { formatFileSize } = require('../lib/file-share.js');

function quoteReply(msg) {
  const rm = msg.reply_to_message;
  if (!rm || !rm.text) return '';
  const replyFrom = rm.from?.username
    ? `@${rm.from.username}`
    : [rm.from?.first_name, rm.from?.last_name].filter(Boolean).join(' ') || 'unknown';
  const senderType = rm.from?.is_bot ? 'assistant' : 'user';
  let maxBackticks = 0;
  for (let i = 0, cur = 0; i < rm.text.length; i++) {
    if (rm.text[i] === '`') { cur++; maxBackticks = Math.max(maxBackticks, cur); }
    else cur = 0;
  }
  const fence = '`'.repeat(Math.max(3, maxBackticks + 1));
  return `In response to ${replyFrom} (${senderType}):\n\n${fence}\n${rm.text}\n${fence}\n\n`;
}

// ---------------------------------------------------------------------------
// File upload helpers
// ---------------------------------------------------------------------------

// Handle an uploaded file from Telegram.
// Returns a notification message with fileId so the agent can download it on demand.
async function handleFileUpload(token, msg, projectDir) {
  const doc = msg.document;
  const photo = msg.photo;
  if (!doc && !photo) return null;

  let fileId;
  let fileName;
  let fileSize;

  if (doc) {
    fileId = doc.file_id;
    fileName = doc.file_name || 'upload.bin';
    fileSize = doc.file_size || 0;
  } else if (photo) {
    const largest = photo[photo.length - 1];
    fileId = largest.file_id;
    fileName = 'photo.jpg';
    fileSize = largest.file_size || 0;
  }

  const sizeStr = fileSize > 0 ? ` (${formatFileSize(fileSize)})` : '';
  return `📎 File uploaded: \`${fileName}\`${sizeStr}\n` +
    `Use \`[Telegram]{"command":"download","fileId":"${fileId}","path":"<destination>"}\` to save it.`;
}

