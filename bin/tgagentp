const http = require('http');
const https = require('https');
const fs = require('fs');
const path = require('path');
const { version } = require('../package.json');
const { sendText, listenForFinalAnswer, listSessions, createSession, updateSession, selectSession, sendToSession, sendToSessionAsync, respondToPermission, listenForSessionEvents, listAgents, listProviders } = require('../lib/opencode.js');

// Logger: info‚Üístdout, error‚Üístderr (always), debug‚Üístderr (--verbose only)
const log = {
  verbose: false,
  info(msg) { process.stdout.write(`${new Date().toISOString().replace('T', ' ').replace(/\.\d{3}Z$/, '')} ${msg}\n`); },
  error(msg) { process.stderr.write(`${msg}\n`); },
  debug(msg) { if (this.verbose) process.stderr.write(`${msg}\n`); },
};

const STARTUP_CHAT_FILE = '/tmp/tgagentp-startup-chat';
const TGAGENTP_PORT = parseInt(process.env.TGAGENTP_PORT || '0', 10);
const PORT_FILE = '/tmp/tgagentp-port';
const TGAGENTP_DEBOUNCE_MS = parseInt(process.env.TGAGENTP_DEBOUNCE_MS || '5000', 10);
const { listServers, activateServer } = require('../lib/ocmux.js');

// Agentp gateway message queue, keyed by server URL
const agentpQueues = {};

function validateAgentpAuth(req) {
  const password = process.env.OPENCODE_SERVER_PASSWORD;
  if (!password) return true;
  const username = process.env.OPENCODE_SERVER_USERNAME || 'opencode';
  const expected = 'Basic ' + Buffer.from(`${username}:${password}`).toString('base64');
  return req.headers.authorization === expected;
}

function flushAgentpQueue(server, token, chatId) {
  if (!chatId) return;
  const q = agentpQueues[server];
  if (!q || q.messages.length === 0) return;
  const msgs = q.messages.splice(0);
  q.notified = false;
  if (q.notifyTimer) { clearTimeout(q.notifyTimer); q.notifyTimer = null; }
  sendLongMessage(token, chatId,
    `üì® Delivering ${msgs.length} queued agentp message(s):`)
    .then(() => {
      for (const msg of msgs) {
        sendLongMessage(token, chatId, msg.trim()).catch(() => {});
      }
    })
    .catch(() => {});
}

// ---------------------------------------------------------------------------
// Telegram Bot API helpers
// ---------------------------------------------------------------------------

function telegramRequest(token, method, params) {
  return new Promise((resolve, reject) => {
    const body = JSON.stringify(params || {});
    const options = {
      hostname: 'api.telegram.org',
      port: 443,
      path: `/bot${token}/${method}`,
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Content-Length': Buffer.byteLength(body),
      },
    };
    const req = https.request(options, (res) => {
      let data = '';
      res.on('data', (chunk) => { data += chunk; });
      res.on('end', () => {
        try {
          resolve(JSON.parse(data));
        } catch (e) {
          reject(new Error(`Failed to parse Telegram response: ${data}`));
        }
      });
    });
    req.on('error', reject);
    req.write(body);
    req.end();
  });
}

function getUpdates(token, offset, timeout) {
  return telegramRequest(token, 'getUpdates', {
    offset,
    timeout: timeout != null ? timeout : 30,
    allowed_updates: ['message'],
  });
}

function sendTelegramMessage(token, chatId, text, parseMode, replyTo) {
  const params = { chat_id: chatId, text };
  if (parseMode) params.parse_mode = parseMode;
  if (replyTo) params.reply_to_message_id = replyTo;
  return telegramRequest(token, 'sendMessage', params);
}

// Lightweight Markdown to Telegram HTML conversion.
function convertMarkdownToHtml(text) {
  const parts = text.split('```');

  return parts.map((part, i) => {
    if (i % 2 === 1) {
      // Code block ‚îÄ strip language tag, escape entities, wrap in <pre>
      const nl = part.indexOf('\n');
      const inner = nl >= 0 ? part.slice(nl + 1) : part;
      return '<pre>' + inner
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;') + '</pre>';
    }

    // Text segment

    // Phase 1: extract table blocks into placeholders
    const placeholders = [];
    let processed = '';
    const lines = part.split('\n');
    let li = 0;
    while (li < lines.length) {
      if (/^\|/.test(lines[li])) {
        const table = [];
        while (li < lines.length && /^\|/.test(lines[li])) {
          table.push(lines[li]);
          li++;
        }
        const hasSep = table.some(l => /^\|[-:| ]+\|$/.test(l));
        if (table.length >= 2 && hasSep) {
          const cleaned = table
            .map(l => l.replace(/^\|/, '').replace(/\|$/, ''))
            .filter(l => !/^\s*[|:\- ]+\s*$/.test(l));
          if (cleaned.length > 0) {
            const escaped = cleaned.map(l =>
              l.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
            );
            const idx = placeholders.length;
            placeholders.push('<pre>' + escaped.join('\n') + '</pre>');
            processed += '\0T' + idx + '\0\n';
            continue;
          }
        }
        for (const l of table) { processed += l + '\n'; }
      } else {
        processed += lines[li] + '\n';
        li++;
      }
    }

    // Phase 2: escape entities and apply markdown on non-table text
    let html = processed
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;');
    html = html.replace(/`([^`]+)`/g, '<code>$1</code>');
    html = html.replace(/^#{1,6}\s+(.+)$/gm, '<b>$1</b>');
    html = html.replace(/^\s*-{3,}\s*$/gm, '‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ');
    html = html.replace(/\*\*(.+?)\*\*/g, '<b>$1</b>');
    html = html.replace(/\*(.+?)\*/g, '<i>$1</i>');

    // Phase 3: restore table placeholders
    for (let j = 0; j < placeholders.length; j++) {
      html = html.split('\0T' + j + '\0').join(placeholders[j]);
    }

    return html;
  }).join('');
}

// Parse TGAGENTP_ALLOWED_CHAT_IDS env var (comma-separated chat IDs).
// Returns null when unset (all chats allowed), or an array of IDs to filter.
function parseAllowlist(raw) {
  if (!raw || !raw.trim()) return null;
  const ids = raw.split(',').map(s => s.trim()).filter(Boolean);
  return ids.length > 0 ? ids : null;
}

// Split text into chunks of at most maxLength characters,
// breaking at newlines when possible.
function splitMessage(text, maxLength = 4096) {
  if (text.length <= maxLength) return [text];
  const chunks = [];
  let start = 0;
  while (start < text.length) {
    let end = Math.min(start + maxLength, text.length);
    if (end < text.length) {
      const newlinePos = text.lastIndexOf('\n', end);
      if (newlinePos > start) {
        end = newlinePos + 1;
      }
    }
    chunks.push(text.slice(start, end));
    start = end;
  }
  return chunks;
}

// Send a text message to a Telegram chat, splitting into multiple
// messages if it exceeds the 4096-character limit.
// Converts Markdown to Telegram HTML formatting.
// Splits the raw text first, then converts each chunk independently
// to avoid broken HTML tags across messages.
async function sendLongMessage(token, chatId, text, replyTo) {
  const chunks = splitMessage(text);
  for (let i = 0; i < chunks.length; i++) {
    const html = convertMarkdownToHtml(chunks[i]);
    await sendTelegramMessage(token, chatId, html, 'HTML', i === 0 ? replyTo : undefined);
  }
}

// Build a quoted reply context from a Telegram reply_to_message.
// Returns empty string if the message isn't a reply or has no text.
// Uses a dynamic code-fence length (max consecutive backticks + 1)
// so nested backticks never break the structure.
function quoteReply(msg) {
  const rm = msg.reply_to_message;
  if (!rm || !rm.text) return '';
  const replyFrom = rm.from?.username
    ? `@${rm.from.username}`
    : [rm.from?.first_name, rm.from?.last_name].filter(Boolean).join(' ') || 'unknown';
  const senderType = rm.from?.is_bot ? 'assistant' : 'user';
  let maxBackticks = 0;
  for (let i = 0, cur = 0; i < rm.text.length; i++) {
    if (rm.text[i] === '`') { cur++; maxBackticks = Math.max(maxBackticks, cur); }
    else cur = 0;
  }
  const fence = '`'.repeat(maxBackticks + 1);
  return `In response to ${replyFrom} (${senderType}):\n\n${fence}\n${rm.text}\n${fence}\n\n`;
}

