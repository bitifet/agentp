async function cmdHelp(token, chatId, args) {
  if (args.length > 0) {
    const topic = args[0].toLowerCase();
    if (topic === 'servers') {
      await sendLongMessage(token, chatId,
        '`/servers` ‚îÄ list all opencode servers (ocmux sessions)\n' +
        '`/servers switch <name>` ‚îÄ switch target server\n\n' +
        '`<name>` can be a full path or basename of the project directory.');
      return;
    }
    if (topic === 'sessions') {
      await sendLongMessage(token, chatId,
        '`/sessions` ‚îÄ list active sessions (numbered, newest first, max 50)\n' +
        '`/sessions switch <number-or-name>` ‚îÄ send messages to a specific session\n' +
        '`/sessions new [name]` ‚îÄ create a new session\n' +
        '`/sessions rename <name>` ‚îÄ rename the active session\n\n' +
        'Switch by number (from the list) or by case-insensitive partial name match.\n' +
        'Use `/sessions` to find session numbers.');
      return;
    }
    if (topic === 'shutdown') {
      await sendLongMessage(token, chatId,
        '`/shutdown` ‚îÄ stop tgagentp process\n' +
        '`/shutdown force` ‚îÄ force shutdown even if busy (in-flight work will be lost)\n\n' +
        'Only available when tgagentp is started with `--dev` flag.\n' +
        'Useful when running tgagentp in a restart loop:\n' +
        '`while true; do tgagentp --dev; done`');
      return;
    }
    if (topic === 'agents') {
      await sendLongMessage(token, chatId,
        '`/agents` ‚îÄ list primary agents (with ‚ñ∂ marker for the active one).\n' +
        '`/agents switch <name>` ‚îÄ switch the active agent. Subsequent messages will use this agent.\n\n' +
        'Agent switching requires an active session (`/sessions switch` or `/sessions new`).');
      return;
    }
    if (topic === 'session') {
      await sendLongMessage(token, chatId,
        '`/session` is an alias for `/sessions`.\n\n' +
        '`/sessions` ‚îÄ list active sessions\n' +
        '`/sessions switch <number-or-name>` ‚îÄ switch to a session\n' +
        '`/sessions new [name]` ‚îÄ create a new session\n' +
        '`/sessions rename <name>` ‚îÄ rename the active session');
      return;
    }
    if (topic === 'models') {
      await sendLongMessage(token, chatId,
        '`/models` ‚îÄ list all providers and their models.\n' +
        'Shows provider name, connection status, default model, and up to 5 models per provider\n' +
        'with status, context limit, and input/output costs.');
      return;
    }
    if (topic === 'allow' || topic === 'reject' || topic === 'always') {
      await sendLongMessage(token, chatId,
        '`/allow` ‚îÄ approve a permission request once\n' +
        '`/reject` ‚îÄ deny a permission request\n' +
        '`/always` ‚îÄ approve and remember for the session\n\n' +
        'These commands respond to OpenCode permission prompts forwarded by tgagentp.\n' +
        'When OpenCode needs approval (e.g. to run a shell command), tgagentp sends a\n' +
        'üîê notification to the chat. Use one of these commands to answer.');
      return;
    }
    if (topic === 'think') {
      await sendLongMessage(token, chatId,
        '`/think` ‚îÄ toggle thinking message forwarding\n' +
        '`/think on` ‚îÄ forward model thinking to the chat in real-time\n' +
        '`/think off` ‚îÄ stop forwarding thinking messages (default)\n' +
        '`/think switch` ‚îÄ toggle current state\n\n' +
        'When enabled, the model\'s internal reasoning steps are sent to the chat\n' +
        'as they are generated, prefixed with üí≠.\n' +
        'Can also be enabled at startup with `--think` flag.');
      return;
    }
    await sendLongMessage(token, chatId,
      'Unknown topic. Try `/help servers`, `/help sessions`, `/help session`, `/help agents`, `/help models`, `/help allow`, `/help think`, or just `/help`.');
    return;
  }
  await sendLongMessage(token, chatId,
    '`/help` ‚îÄ show this message\n' +
    '`/help <topic>` ‚îÄ detailed help\n' +
    '`/status` ‚îÄ show current server and session\n' +
    '`/cancel` ‚îÄ cancel the running prompt\n' +
    '`/servers` ‚îÄ list running opencode servers\n' +
    '`/servers switch <name>` ‚îÄ switch to a different server\n' +
    '`/sessions` ‚îÄ list/create/switch/rename sessions\n' +
    '`/sessions switch <number-or-name>` ‚îÄ switch to a session\n' +
    '`/sessions new [name]` ‚îÄ create a new session\n' +
    '`/sessions rename <name>` ‚îÄ rename the active session\n' +
    '`/session` ‚îÄ alias for `/sessions`\n' +
    '`/agents` ‚îÄ list available agents\n' +
    '`/agents switch <name>` ‚îÄ switch active agent\n' +
    '`/models` ‚îÄ list providers and models\n' +
    '`/think` ‚îÄ toggle thinking message forwarding\n' +
    '`/allow` / `/reject` / `/always` ‚îÄ respond to permission requests\n' +
    '`/shutdown` ‚îÄ stop tgagentp (only with `--dev` flag)\n\n' +
    'Everything else is forwarded to the active server as `[Telegram] <text>`.');
}

async function cmdServers(token, chatId, args, setServer, setActiveSession, serverBase) {
  if (args.length > 0 && args[0].toLowerCase() === 'switch') {
    if (args.length < 2) {
      await sendLongMessage(token, chatId,
        'Usage: `/servers switch <name>`\n' +
        '`<name>` can be a full directory path or a basename.');
      return;
    }
    const name = args.slice(1).join(' ');
    const servers = listServers();
    if (servers.length === 0) {
      await sendLongMessage(token, chatId, 'No servers running.');
      return;
    }
    let matches = servers.filter(s => s.dir === name);
    if (matches.length === 0) {
      matches = servers.filter(s => path.basename(s.dir) === name);
    }
    if (matches.length === 0) {
      matches = servers.filter(s => s.dir.includes(name) || path.basename(s.dir).includes(name));
    }
    if (matches.length === 0) {
      await sendLongMessage(token, chatId, `No server found matching "${name}".`);
      return;
    }
    if (matches.length > 1) {
      const list = matches.map(s => `  ${s.url} ‚Üí ${s.dir}`).join('\n');
      await sendLongMessage(token, chatId,
        `Multiple matches for "${name}":\n${list}\n\nPlease be more specific.`);
      return;
    }
    const target = matches[0];
    const pending = await setServer(target.url);
    activateServer(target.dir, target.index, target.url);
    let msg = `Switched to server: ${target.url} ‚Üí ${target.dir}`;
    if (pending && pending.trim()) {
      await sendLongMessage(token, chatId, msg);
      await sendLongMessage(token, chatId, pending.trim());
    } else {
      await sendLongMessage(token, chatId, msg);
    }
    return;
  }

  // Default: list servers
  const servers = listServers();
  if (servers.length === 0) {
    await sendLongMessage(token, chatId, 'No servers running.');
    return;
  }
  const activeUrl = normalizeUrl(serverBase);
  const lines = servers.map(s => {
    const bullet = normalizeUrl(s.url) === activeUrl ? '‚ñ∂ ' : ' ¬∑ ';
    return bullet + `${s.url} ‚Üí ${s.dir} (${s.status})`;
  });
  await sendLongMessage(token, chatId, 'Active servers:\n' + lines.join('\n'));
}

function sessionName(s) {
  return s.title || s.slug || s.id;
}

function normalizeUrl(url) {
  return url.replace(/\/+$/, '').replace(/^http:\/\/127\.0\.0\.1:/, 'http://localhost:');
}

function serverDir(serverUrl) {
  const servers = listServers();
  const normalized = normalizeUrl(serverUrl);
  const found = servers.find(s => normalizeUrl(s.url) === normalized);
  return found ? found.dir : null;
}

// Sort by time.updated descending, limit to N.
function sortedSessions(sessions, limit) {
  return sessions
    .filter(s => s.time && s.time.updated)
    .sort((a, b) => b.time.updated - a.time.updated)
    .slice(0, limit || 50);
}

// Find the most recently updated session and return its ID and name.
// Returns null if no sessions exist or the server is unreachable.
async function discoverActiveSession(server) {
  try {
    const sessions = await listSessions(server);
    if (!sessions || sessions.length === 0) return null;
    const sorted = sortedSessions(sessions, 1);
    if (sorted.length === 0) return null;
    const s = sorted[0];
    return { id: s.id, name: sessionName(s) };
  } catch {
    return null;
  }
}

async function cmdSessions(token, chatId, args, setServer, setActiveSession, server) {
  if (args.length > 0) {
    const sub = args[0].toLowerCase();

    if (sub === 'new') {
      const title = args.slice(1).join(' ') || undefined;
      try {
        const session = await createSession(server, title);
        const name = session.title || session.slug || session.id;
        setActiveSession(session.id);
        selectSession(server, session.id);
        await sendLongMessage(token, chatId,
          `Created session: \`${name}\`\nIt is now the active session.`);
      } catch (err) {
        await sendLongMessage(token, chatId, `Error creating session: ${err.message}`);
      }
      return;
    }

    if (sub === 'rename') {
      if (args.length < 2) {
        await sendLongMessage(token, chatId, 'Usage: `/sessions rename <name>`');
        return;
      }
      const st = getState(server);
      if (!st.activeSessionId) {
        await sendLongMessage(token, chatId, 'No active session. Use `/sessions switch` or `/sessions new` first.');
        return;
      }
      const newTitle = args.slice(1).join(' ');
      try {
        const session = await updateSession(server, st.activeSessionId, newTitle);
        const name = session.title || session.slug || session.id;
        await sendLongMessage(token, chatId,
          `Renamed session to: \`${name}\``);
      } catch (err) {
        await sendLongMessage(token, chatId, `Error renaming session: ${err.message}`);
      }
      return;
    }

    if (sub === 'switch') {
      if (args.length < 2) {
        await sendLongMessage(token, chatId,
          'Usage: `/sessions switch <number-or-name>`\n' +
          'Use `/sessions` to see numbered list. You can switch by number or by name (case-insensitive partial match).');
        return;
      }
      const query = args.slice(1).join(' ');
      try {
        const projectDir = serverDir(server);
        const sessions = await listSessions(server, projectDir);
        const activeId = getState(server).activeSessionId;
        const filtered = sessions.filter(s =>
          (s.agent || s.directory || s.id === activeId) && (!projectDir || s.directory === projectDir));
        const sorted = sortedSessions(filtered, 50);

        // Try by position number first
        const num = parseInt(query, 10);
        if (/^\d+$/.test(query) && num >= 1 && num <= sorted.length) {
          const target = sorted[num - 1];
          setActiveSession(target.id);
          selectSession(server, target.id);
          await sendLongMessage(token, chatId,
            `Switched to session #${num}: \`${sessionName(target)}\`\nSubsequent messages will be sent to this session.`);
          return;
        }

        // Try by name (case-insensitive partial match)
        const q = query.toLowerCase();
        const matches = sorted.filter(s => sessionName(s).toLowerCase().includes(q));
        if (matches.length === 0) {
          await sendLongMessage(token, chatId,
            `No session matching "${query}". Use /sessions to list active sessions.`);
          return;
        }
        if (matches.length > 1) {
          const list = matches.map(s => `  \`${sessionName(s)}\``).join('\n');
          await sendLongMessage(token, chatId,
            `Multiple matches for "${query}":\n${list}\n\nPlease be more specific or use a number.`);
          return;
        }
        const target = matches[0];
        setActiveSession(target.id);
        selectSession(server, target.id);
        await sendLongMessage(token, chatId,
          `Switched to session: \`${sessionName(target)}\`\nSubsequent messages will be sent to this session.`);
      } catch (err) {
        await sendLongMessage(token, chatId, `Error switching session: ${err.message}`);
      }
      return;
    }

    // Unknown subcommand
    await sendLongMessage(token, chatId,
      `Unknown subcommand: /sessions ${sub}\n\n` +
      'Usage:\n' +
      '  `/sessions` ‚îÄ list sessions\n' +
      '  `/sessions switch <number-or-name>` ‚îÄ switch to a session\n' +
      '  `/sessions new [name]` ‚îÄ create a new session\n' +
      '  `/sessions rename <name>` ‚îÄ rename the active session');
    return;
  }

  // Default: list sessions
  try {
    const projectDir = serverDir(server);
    const sessions = await listSessions(server, projectDir);
    if (!sessions || sessions.length === 0) {
      await sendLongMessage(token, chatId, 'No active sessions.');
      return;
    }

    // Show user sessions (have agent or directory) and always include the active session
    const activeId = getState(server).activeSessionId;
    const filtered = sessions.filter(s =>
      (s.agent || s.directory || s.id === activeId) && (!projectDir || s.directory === projectDir));
    const sorted = sortedSessions(filtered, 50);
    if (sorted.length === 0) {
      await sendLongMessage(token, chatId, 'No active sessions.');
      return;
    }

    // Build lines with date headings and time labels
    const now = new Date();
    const todayStr = now.toLocaleDateString();
    const oneWeekAgo = new Date(now);
    oneWeekAgo.setDate(oneWeekAgo.getDate() - 7);

    const lines = [];
    let currentHeading = null;

    sorted.forEach((s, idx) => {
      const created = new Date(s.time.updated);
      const isToday = created.toLocaleDateString() === todayStr;
      const isRecent = created >= oneWeekAgo;

      let heading;
      if (isToday) {
        heading = '**Today**';
      } else if (isRecent) {
        heading = '**' + created.toLocaleDateString(undefined, { weekday: 'short', month: 'short', day: 'numeric' }) + '**';
      } else {
        heading = '**' + created.getFullYear() + '-' + String(created.getMonth() + 1).padStart(2, '0') + '**';
      }
      if (heading !== currentHeading) {
        lines.push('');
        lines.push(heading);
        currentHeading = heading;
      }

      const hh = String(created.getHours()).padStart(2, '0');
      const mm = String(created.getMinutes()).padStart(2, '0');
      const timeLabel = isRecent
        ? `[${hh}:${mm}]`
        : `[${String(created.getDate()).padStart(2, '0')}/${String(created.getMonth() + 1).padStart(2, '0')} - ${hh}:${mm}]`;

      const name = sessionName(s);
      const pos = idx + 1;
      const bullet = s.id === activeId ? '‚ñ∂ ' : ' ¬∑ ';
      lines.push('`' + bullet + pos + ' ' + timeLabel + ' ‚Äì ' + name.replace(/`/g, "'") + '`');
    });

    await sendLongMessage(token, chatId, 'Sessions:\n' + lines.join('\n'));
  } catch (err) {
    await sendLongMessage(token, chatId, `Error listing sessions: ${err.message}`);
  }
}

async function cmdAgents(token, chatId, args, setServer, setActiveSession, server) {
  if (args.length > 0 && args[0].toLowerCase() === 'switch') {
    if (args.length < 2) {
      await sendLongMessage(token, chatId,
        'Usage: `/agents switch <name>`\n' +
        'Use `/agents` to list available agents.');
      return;
    }
    const name = args.slice(1).join(' ');
    try {
      const agents = await listAgents(server);
      if (!agents || agents.length === 0) {
        await sendLongMessage(token, chatId, 'No agents available.');
        return;
      }
      let matches = agents.filter(a => a.name === name);
      if (matches.length === 0) {
        matches = agents.filter(a => a.name.toLowerCase().includes(name.toLowerCase()));
      }
      if (matches.length === 0) {
        await sendLongMessage(token, chatId, `No agent matching "${name}".`);
        return;
      }
      if (matches.length > 1) {
        const list = matches.map(a => `  \`${a.name}\``).join('\n');
        await sendLongMessage(token, chatId,
          `Multiple matches for "${name}":\n${list}\n\nPlease be more specific.`);
        return;
      }
      const target = matches[0];
      getState(server).activeAgentName = target.name;
      const st = getState(server);
      if (st.activeSessionId) {
        updateSession(server, st.activeSessionId, undefined, target.name);
        selectSession(server, st.activeSessionId);
      }
      const model = target.model ? ` ‚îÄ \`${target.model.providerID}/${target.model.modelID}\`` : '';
      await sendLongMessage(token, chatId,
        `Switched to agent: **${target.name}**${model}\nSubsequent messages will use this agent.`);
    } catch (err) {
      await sendLongMessage(token, chatId, `Error switching agent: ${err.message}`);
    }
    return;
  }

  try {
    const agents = await listAgents(server);
    if (!agents || agents.length === 0) {
      await sendLongMessage(token, chatId, 'No agents available.');
      return;
    }
    const primary = agents.filter(a => a.mode === 'primary');
    if (primary.length === 0) {
      await sendLongMessage(token, chatId, 'No primary agents available.');
      return;
    }
    const activeAgentName = getState(server).activeAgentName;
    const lines = primary.map(a => {
      const bullet = a.name === activeAgentName ? '‚ñ∂ ' : ' ¬∑ ';
      const model = a.model ? ` ‚îÄ \`${a.model.providerID}/${a.model.modelID}\`` : '';
      const desc = a.description ? `. ${a.description}` : '';
      return bullet + '**' + a.name + '**' + model + desc;
    });
    await sendLongMessage(token, chatId, 'Primary agents:\n' + lines.join('\n'));
  } catch (err) {
    await sendLongMessage(token, chatId, `Error listing agents: ${err.message}`);
  }
}

async function cmdModels(token, chatId, args, setServer, setActiveSession, server) {
  try {
    const result = await listProviders(server);
    const all = result.all || [];
    const connectedIds = result.connected || [];

    const filtered = all.filter(p => connectedIds.includes(p.id));
    if (filtered.length === 0) {
      await sendLongMessage(token, chatId, 'No connected providers.');
      return;
    }

    const lines = [];

    for (const provider of filtered) {
      lines.push('');
      lines.push('**' + provider.name + '** ‚úÖ');

      const modelEntries = Object.entries(provider.models || {});
      if (modelEntries.length === 0) continue;

      const shown = modelEntries.slice(0, 5);
      for (const [id, model] of shown) {
        const ctx = model.limit ? Math.round(model.limit.context / 1000) + 'K' : '';
        const cost = model.cost ? ` $${model.cost.input}/${model.cost.output}` : '';
        lines.push('  `' + id + '`' + (ctx ? ' ' + ctx : '') + cost);
      }
      if (modelEntries.length > 5) {
        lines.push('  *‚Ä¶and ' + (modelEntries.length - 5) + ' more*');
      }
    }

    await sendLongMessage(token, chatId, 'Connected providers:\n' + lines.join('\n'));
  } catch (err) {
    await sendLongMessage(token, chatId, `Error listing models: ${err.message}`);
  }
}

const PERM_RESPONSE_HELP = ' No pending permission. Use `/status` to check the current state.';

// ---------------------------------------------------------------------------
// Agentp gateway ‚îÄ tiny HTTP server for agentp --tg
// ---------------------------------------------------------------------------

function startAgentpGateway(token, chatIdResolver, serverBaseResolver) {
  return new Promise((resolve) => {
    const server = http.createServer((req, res) => {
      try {
        if (req.method !== 'POST' || req.url !== '/send') {
          res.writeHead(405);
          res.end('Method Not Allowed');
          return;
        }
        if (!validateAgentpAuth(req)) {
          res.writeHead(401);
          res.end('Unauthorized');
          return;
        }
        let body = '';
        req.on('data', (chunk) => { body += chunk; });
        req.on('end', () => {
          try {
            let data;
            try { data = JSON.parse(body); } catch {
              res.writeHead(400);
              res.end('Bad Request');
              return;
            }
            const { text, server } = data;
            if (typeof text !== 'string' || typeof server !== 'string') {
              res.writeHead(400);
              res.end('Bad Request: text and server are required');
              return;
            }
            res.writeHead(200);
            res.end('OK');

            const chatId = chatIdResolver();
            if (!chatId) return;
            const activeUrl = normalizeUrl(serverBaseResolver());
            const targetUrl = normalizeUrl(server);

            if (targetUrl === activeUrl) {
              sendLongMessage(token, chatId, text.trim()).catch(() => {});
            } else {
              if (!agentpQueues[server]) {
                agentpQueues[server] = { messages: [], notifyTimer: null, notified: false };
              }
              const q = agentpQueues[server];
              q.messages.push(text);
              if (!q.notifyTimer) {
                q.notifyTimer = setTimeout(() => {
                  q.notifyTimer = null;
                  if (q.messages.length > 0 && !q.notified) {
                    q.notified = true;
                    sendLongMessage(token, chatId,
                      `üì• ${q.messages.length} agentp message(s) queued for server \`${server}\`. Switch servers to view them.`)
                      .catch(() => {});
                  }
                }, TGAGENTP_DEBOUNCE_MS);
              }
            }
          } catch (err) {
            log.error(`Agentp gateway handler error: ${err.message}`);
          }
        });
      } catch (err) {
        log.error(`Agentp gateway handler error: ${err.message}`);
      }
    });
    server.on('error', (err) => {
      log.error(`Agentp gateway server error: ${err.message}`);
    });
    server.listen(TGAGENTP_PORT, '127.0.0.1', () => {
      const port = server.address().port;
      try { fs.writeFileSync(PORT_FILE, String(port)); } catch (_) {}
      log.info(`Agentp gateway listening on port ${port}`);
      resolve(port);
    });
  });
}

async function cmdAllow(token, chatId, args, setServer, setActiveSession, server) {
  const st = getState(server);
  if (!st.pendingPermission) {
    await sendLongMessage(token, chatId, '/allow' + PERM_RESPONSE_HELP);
    return;
  }
  const p = st.pendingPermission;
  try {
    await respondToPermission(p.server, p.sessionId, p.permissionId, 'once');
    await sendLongMessage(token, chatId, '‚úÖ Permission approved (once).');
    log.debug(`  ‚Üí /allow: ${p.type} ${p.pattern || ''}`);
  } catch (err) {
    await sendLongMessage(token, chatId, `Error: ${err.message}`);
  }
}

async function cmdReject(token, chatId, args, setServer, setActiveSession, server) {
  const st = getState(server);
  if (!st.pendingPermission) {
    await sendLongMessage(token, chatId, '/reject' + PERM_RESPONSE_HELP);
    return;
  }
  const p = st.pendingPermission;
  try {
    await respondToPermission(p.server, p.sessionId, p.permissionId, 'reject');
    await sendLongMessage(token, chatId, '‚õî Permission denied.');
    log.debug(`  ‚Üí /reject: ${p.type} ${p.pattern || ''}`);
  } catch (err) {
    await sendLongMessage(token, chatId, `Error: ${err.message}`);
  }
}

async function cmdAlways(token, chatId, args, setServer, setActiveSession, server) {
  const st = getState(server);
  if (!st.pendingPermission) {
    await sendLongMessage(token, chatId, '/always' + PERM_RESPONSE_HELP);
    return;
  }
  const p = st.pendingPermission;
  try {
    await respondToPermission(p.server, p.sessionId, p.permissionId, 'always');
    await sendLongMessage(token, chatId, '‚úÖ Permission approved (always).');
    log.debug(`  ‚Üí /always: ${p.type} ${p.pattern || ''}`);
  } catch (err) {
    await sendLongMessage(token, chatId, `Error: ${err.message}`);
  }
}

async function cmdThink(token, chatId, args, setServer, setActiveSession, server) {
  const st = getState(server);
  const sub = args && args.length > 0 ? args[0].toLowerCase() : 'switch';
  if (sub === 'on') {
    st.thinkingEnabled = true;
    await sendLongMessage(token, chatId, 'üí≠ Thinking messages **on** (forwarded to chat).');
  } else if (sub === 'off') {
    st.thinkingEnabled = false;
    await sendLongMessage(token, chatId, 'üí≠ Thinking messages **off**.');
  } else if (sub === 'switch') {
    st.thinkingEnabled = !st.thinkingEnabled;
    await sendLongMessage(token, chatId,
      `üí≠ Thinking messages ${st.thinkingEnabled ? '**on**' : '**off**'}.`);
  } else {
    await sendLongMessage(token, chatId, 'Usage: `/think [on|off|switch]` (default: switch).');
  }
}

const COMMANDS = {
  'help': cmdHelp,
  'servers': cmdServers,
  'sessions': cmdSessions,
  'session': cmdSessions,
  'agents': cmdAgents,
  'models': cmdModels,
  'think': cmdThink,
  'allow': cmdAllow,
  'reject': cmdReject,
  'always': cmdAlways,
};

// --------------------------------------------------------------------------
// Module-level state
// ---------------------------------------------------------------------------

const serverState = {};
function getState(url) {
  return serverState[url] = serverState[url] || { busy: false, pendingResponse: null, activeSessionId: null, activeSessionName: null, activeAgentName: null, taskId: 0, pendingPermission: null, thinkingEnabled: false };
}

function sessionLabel(st) {
  if (st.activeSessionName) return '`' + st.activeSessionName + '`';
  if (st.activeSessionId) return '`' + st.activeSessionId + '`';
  return '*none (TUI+SSE)*';
}

// --------------------------------------------------------------------------
// Main
// ---------------------------------------------------------------------------

async function main() {
  let serverBase = 'http://localhost:4096';

  let DEV_MODE = false;

  const args = process.argv.slice(2);
  for (let i = 0; i < args.length; i++) {
    if (args[i] === '--version') {
      console.log(version);
      process.exit(0);
    } else if (args[i] === '--dev') {
      DEV_MODE = true;
    } else if (args[i] === '--verbose') {
      log.verbose = true;
    } else if (args[i] === '--think') {
      getState(serverBase).thinkingEnabled = true;
    } else if (args[i] === '--help') {
      console.error('Usage: tgagentp [options] [url]');
      console.error('');
      console.error('Bridge a Telegram bot chat with an OpenCode TUI session.');
      console.error('Incoming Telegram messages are forwarded to OpenCode; answers are sent back to the chat.');
      console.error('');
      console.error('Options:');
      console.error('  --dev       Enable development mode (adds /shutdown command)');
      console.error('  --version   Show version');
      console.error('  --verbose   Show detailed logs (errors, trace, debug) on stderr');
      console.error('  --think     Start with thinking messages enabled (default: off)');
      console.error('  --help      Show this help message');
      console.error('');
      console.error('Arguments:');
      console.error('  url        OpenCode TUI server URL or port number (default: 4096)');
      console.error('             Examples: 4096, http://localhost:4096, http://192.168.1.50:4096');
      console.error('');
      console.error('Environment variables:');
      console.error('  TELEGRAM_BOT_TOKEN         Telegram bot token (required)');
      console.error('  OPENCODE_SERVER_PASSWORD    OpenCode server password (optional, also used for agentp gateway auth)');
      console.error('  OPENCODE_SERVER_USERNAME    OpenCode server username (optional, default: opencode)');
      console.error('  TGAGENTP_ALLOWED_CHAT_IDS   Comma-separated Telegram chat IDs (optional)');
      console.error('                               Example: "123456,-789012"');
      console.error('  TGAGENTP_PORT               Agentp gateway listen port (optional, default: random)');
      console.error('  TGAGENTP_DEBOUNCE_MS        Debounce interval for queued agentp messages (optional, default: 5000)');
      console.error('');
      console.error('Also starts an agentp gateway (tiny HTTP server on localhost) that');
      console.error('accepts POST /send from agentp --tg and forwards answers to Telegram.');
      console.error('');
      console.error('See also: agentp, ocmux');
      console.error('');
      console.error('Examples:');
      console.error('  export TELEGRAM_BOT_TOKEN="your-bot-token"');
      console.error('  tgagentp');
      console.error('  tgagentp 4096');
      console.error('  tgagentp http://192.168.1.50:4096');
      process.exit(0);
    } else if (args[i].includes('://')) {
      serverBase = args[i].replace(/\/+$/, '');
    } else if (/^\d+$/.test(args[i])) {
      serverBase = 'http://localhost:' + args[i];
    }
  }

  const token = process.env.TELEGRAM_BOT_TOKEN;
  if (!token) {
    console.error('Error: TELEGRAM_BOT_TOKEN environment variable is not set.');
    console.error('Create a bot with @BotFather on Telegram and export the token before running tgagentp.');
    process.exit(1);
  }

  log.info(`tgagentp v${version} started. OpenCode server: ${serverBase}`);

  if (!process.env.OPENCODE_SERVER_PASSWORD) {
    log.error('üîì  Server is not password-protected! Set OPENCODE_SERVER_PASSWORD for better security.');
  }

  const allowedChatIds = parseAllowlist(process.env.TGAGENTP_ALLOWED_CHAT_IDS);
  if (allowedChatIds) {
    log.info(`Chat allowlist: ${allowedChatIds.length} chat(s) configured`);
  } else {
    log.info('Chat allowlist: not configured (all chats accepted)');
  }

  let lockedChatId = null;

  getState(serverBase);

  log.info('Discovering server state...');
  const [discovered, agents] = await Promise.all([
    discoverActiveSession(serverBase),
    listAgents(serverBase).catch(() => []),
  ]);
  if (discovered) {
    getState(serverBase).activeSessionId = discovered.id;
    getState(serverBase).activeSessionName = discovered.name;
    log.info(`  ‚Üí session: ${discovered.name || discovered.id}`);
  }
  const defaultAgent = agents.find(a => a.mode === 'primary') || agents[0];
  if (defaultAgent) {
    getState(serverBase).activeAgentName = defaultAgent.name;
    log.info(`  ‚Üí agent: ${defaultAgent.name}`);
  }

  log.info('Waiting for Telegram messages... (Ctrl+C to stop)');

  // Start agentp gateway (tiny HTTP server for agentp --tg)
  const chatIdResolver = () => lockedChatId;
  const serverBaseResolver = () => serverBase;
  startAgentpGateway(token, chatIdResolver, serverBaseResolver);

  const setServer = async (url) => {
    serverBase = url;
    getState(url);
    log.info(`Switched to server: ${url}`);

    // Flush agentp queue for the new active server
    flushAgentpQueue(url, token, lockedChatId);

    const [discovered, agents] = await Promise.all([
      discoverActiveSession(url),
      listAgents(url).catch(() => []),
    ]);
    if (discovered) {
      getState(url).activeSessionId = discovered.id;
      getState(url).activeSessionName = discovered.name;
      log.info(`  ‚Üí session: ${discovered.name || discovered.id}`);
    }
    const defaultAgent = agents.find(a => a.mode === 'primary') || agents[0];
    if (defaultAgent) {
      getState(url).activeAgentName = defaultAgent.name;
      log.info(`  ‚Üí agent: ${defaultAgent.name}`);
    }
    const p = getState(url).pendingResponse;
    if (p) {
      getState(url).pendingResponse = null;
      return p;
    }
    return null;
  };

  const setActiveSession = (id) => {
    getState(serverBase).activeSessionId = id;
    log.info(`Switched to session: ${id}`);
  };

  async function processMessageAsync(chatId, text, url, useSession, sessionId, myTaskId, replyTo) {
    const st = getState(url);
    const isCancelled = () => getState(url).taskId !== myTaskId;
    const cancelRef = { current: null };
    const sessionCancelRef = { current: null };
    st._cancelRef = cancelRef;
    st._sessionReq = sessionCancelRef;
    try {
      let answer;
      if (useSession) {
        // Dual approach:
        // 1. SSE for permissions/thinking events (connected before sending)
        // 2. Synchronous sendToSession (POST /session/:id/message) for reliable answer
        const notifiedPerms = new Set();
        let thinkingBuf = '';
        let sseConnected;
        const onConnected = Promise.race([
          new Promise((resolve) => { sseConnected = resolve; }),
          new Promise((resolve) => setTimeout(resolve, 5000)),
        ]);
        listenForSessionEvents(url, sessionId, {
          onText: null,
          onConnected: sseConnected,
          onThinking: (chunk) => {
            if (!getState(url).thinkingEnabled) { thinkingBuf = ''; return; }
            thinkingBuf += chunk;
            if (thinkingBuf.length >= 50 || chunk.endsWith('\n')) {
              const html = 'üí≠ ' + thinkingBuf.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
              sendLongMessage(token, chatId, html, replyTo)
                .then(() => {})
                .catch(() => {});
              thinkingBuf = '';
            }
          },
          onPermission: (perm) => {
            const st2 = getState(url);
            const permDump = JSON.stringify(perm);
            log.debug(`  ‚Üí permission_asked callback: ${permDump}`);
            st2.pendingPermission = { server: url, sessionId, permissionId: perm.id, type: perm.permission || 'unspecified', pattern: perm.patterns || perm.pattern, title: perm.title };
            if (!notifiedPerms.has(perm.id)) {
              notifiedPerms.add(perm.id);
              const toolStr = perm.permission || 'unspecified';
              const patternArr = perm.patterns || (perm.pattern ? [perm.pattern] : []);
              const patternStr = patternArr.join(', ');
              const msg = 'üîê **Permission needed**\n'
                + '**Tool:** `' + toolStr + '`\n'
                + (patternStr ? '**Target:** `' + patternStr + '`\n' : '')
                + (perm.title ? '**Detail:** ' + perm.title + '\n' : '')
                + 'Use `/allow` to approve once, `/always` to always allow, or `/reject` to deny.';
              log.debug(`  ‚Üí sending permission notification to chat ${chatId}`);
              sendLongMessage(token, chatId, msg, replyTo)
                .then(() => log.debug(`  ‚Üí permission notification sent OK`))
                .catch((err) => log.debug(`  ‚Üí permission notification failed: ${err.message}`));
            } else {
              log.debug(`  ‚Üí permission ${perm.id} already notified, updating pendingPermission only`);
            }
          },
          onPermissionReplied: () => {
            log.debug(`  ‚Üí permission_replied: clearing pendingPermission`);
            getState(url).pendingPermission = null;
          },
        }, cancelRef).catch(() => {});
        // Wait for SSE to connect, then send synchronously
        await onConnected;
        answer = await sendToSession(url, sessionId, `[Telegram] ${text}`, st.activeAgentName, sessionCancelRef);
        // Flush any remaining thinking buffer
        if (thinkingBuf) {
          const html = 'üí≠ ' + thinkingBuf.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
          sendLongMessage(token, chatId, html, replyTo).catch(() => {});
          thinkingBuf = '';
        }
        // Clean up SSE listener
        if (cancelRef.current) { cancelRef.current.destroy(); cancelRef.current = null; }
      } else {
        await sendText(url, `[Telegram] ${text}`);
        answer = await listenForFinalAnswer(url, null, cancelRef);
      }
      if (isCancelled()) {
        log.debug(`  ‚Üí cancelled, discarding response from ${url}`);
        st.pendingPermission = null;
        return;
      }
      st.pendingPermission = null;
      if (url === serverBase) {
        if (answer && answer.trim()) {
          await sendLongMessage(token, chatId, answer.trim(), replyTo);
        }
      } else {
        getState(url).pendingResponse = answer;
        await sendLongMessage(token, chatId, `‚úÖ Server \`${url}\` finished processing. Switch back to see the response.`, replyTo);
      }
    } catch (err) {
      // Clean up SSE listener if it's still active
      if (cancelRef.current) { cancelRef.current.destroy(); cancelRef.current = null; }
      if (isCancelled()) {
        log.debug(`  ‚Üí cancelled, ignoring error from ${url}: ${err.message}`);
        st.pendingPermission = null;
        return;
      }
      log.error(`Error processing message (${url}): ${err.message}`);
      if (url === serverBase) {
        try { await sendLongMessage(token, chatId, `Error: ${err.message}`, replyTo); } catch (_) {}
      }
    } finally {
      st.pendingPermission = null;
      if (st._cancelRef === cancelRef) st._cancelRef = null;
      if (st._sessionReq === sessionCancelRef) st._sessionReq = null;
      if (!isCancelled()) {
        getState(url).busy = false;
      }
    }
  }

  const cmdCancel = async (token, chatId) => {
    const st = getState(serverBase);
    if (!st.busy) {
      await sendLongMessage(token, chatId, 'Nothing to cancel.');
      return;
    }
    st.taskId++;
    st.busy = false;
    // Abort the SSE stream so the server stops processing
    if (st._cancelRef && st._cancelRef.current) {
      st._cancelRef.current.destroy();
      st._cancelRef.current = null;
    }
    // Abort the synchronous session request if in progress
    if (st._sessionReq && st._sessionReq.current) {
      st._sessionReq.current.destroy();
      st._sessionReq.current = null;
    }
    await sendLongMessage(token, chatId, '‚úÖ Cancelled.');
    log.debug(`  ‚Üí /cancel on ${serverBase}`);
  }

  const cmdStatus = async (token, chatId) => {
    const st = getState(serverBase);
    const busyInfo = st.busy ? '‚è≥ busy' : '‚úÖ idle';
    const dir = serverDir(serverBase);
    const lines = ['**Server:**'];
    if (dir) lines.push('  ‚Ä¢ **Path:** `' + dir + '`');
    lines.push('  ‚Ä¢ **URL:** `' + serverBase + '`');
    lines.push('  ‚Ä¢ **Status:** ' + busyInfo);
    lines.push('**Session:** ' + sessionLabel(st));
    lines.push('**Agent:** ' + (st.activeAgentName ? '`' + st.activeAgentName + '`' : '*default*'));
    await sendLongMessage(token, chatId, lines.join('\n'));
  };

  const cmdShutdown = async (token, chatId, args) => {
    const st = getState(serverBase);
    const isForce = args && args.length > 0 && args[0].toLowerCase() === 'force';
    if (st.busy && !isForce) {
      await sendLongMessage(token, chatId,
        '‚è≥ Server is busy processing a message.\n' +
        'Use `/shutdown force` to shut down anyway (in-flight response will be lost).');
      return;
    }
    const status = st.busy ? '‚è≥ busy (forced)' : '‚úÖ idle';
    await sendLongMessage(token, chatId, `üëã Shutting down (state: ${status})...`);
    try {
      fs.writeFileSync(STARTUP_CHAT_FILE, String(chatId));
    } catch (_) {}
    try { await getUpdates(token, offset, 1); } catch (_) {}
    log.debug('/shutdown received, exiting...');
    process.exit(0);
  };

  const cmds = { ...COMMANDS, status: cmdStatus, cancel: cmdCancel };
  if (DEV_MODE) cmds.shutdown = cmdShutdown;

  let offset = 0;

  // Startup greeting to last-known chat
  const savedChatId = (() => { try { return fs.readFileSync(STARTUP_CHAT_FILE, 'utf8').trim(); } catch { return null; } })();
  if (savedChatId) {
    const st = getState(serverBase);
    const dir = serverDir(serverBase);
    const lines = ['‚úÖ Bot started.', '**Server:**'];
    if (dir) lines.push('  ‚Ä¢ **Path:** `' + dir + '`');
    lines.push('  ‚Ä¢ **URL:** `' + serverBase + '`');
    lines.push('  ‚Ä¢ **Status:** ‚úÖ idle');
    lines.push('**Session:** ' + sessionLabel(st));
    lines.push('**Agent:** ' + (st.activeAgentName ? '`' + st.activeAgentName + '`' : '*default*'));
    try { await sendLongMessage(token, savedChatId, lines.join('\n')); } catch (_) {}
    lockedChatId = savedChatId;
    try { fs.unlinkSync(STARTUP_CHAT_FILE); } catch (_) {}
  }

  // Poll for updates and forward each text message to OpenCode, sending the answer back.
  while (true) {
    let result;
    try {
      result = await getUpdates(token, offset, 30);
    } catch (err) {
      log.error(`Polling error: ${err.message}`);
      await new Promise((r) => setTimeout(r, 5000));
      continue;
    }

    if (!result.ok) {
      log.error(`Telegram API error: ${result.description || JSON.stringify(result)}`);
      await new Promise((r) => setTimeout(r, 5000));
      continue;
    }

    for (const update of result.result) {
      offset = update.update_id + 1;

      const msg = update.message;
      if (!msg || typeof msg.text !== 'string') {
        // Ignore non-text messages (photos, stickers, etc.)
        continue;
      }

      const chatId = String(msg.chat.id);
      const replyTo = msg.message_id;
      const text = msg.text;
      const from = msg.from?.username
        ? `@${msg.from.username}`
        : [msg.from?.first_name, msg.from?.last_name].filter(Boolean).join(' ') || 'unknown';

      // Enforce chat allowlist if configured
      if (allowedChatIds && !allowedChatIds.includes(chatId)) {
        log.debug(`[chat ${chatId}] ${from}: blocked (not in allowlist)`);
        continue;
      }

      // Lock to the first chat that connects (single-user guard)
      if (lockedChatId === null) {
        lockedChatId = chatId;
        log.debug(`[chat ${chatId}] ${from}: locked to this chat`);
      } else if (lockedChatId !== chatId) {
        log.debug(`[chat ${chatId}] ${from}: blocked (locked to ${lockedChatId})`);
        continue;
      }

      log.debug(`[chat ${chatId}] ${from}: ${text}`);
      try { fs.writeFileSync(STARTUP_CHAT_FILE, String(chatId)); } catch (_) {}

      // Build reply context if this message is a Telegram reply
      const replyContext = quoteReply(msg);

      // Intercept /commands
      if (text.startsWith('/')) {
        const parts = text.slice(1).split(' ');
        const cmd = parts[0].toLowerCase();
        const cmdArgs = parts.slice(1);
        const handler = cmds[cmd];
        if (handler) {
          try {
            await handler(token, chatId, cmdArgs, setServer, setActiveSession, serverBase);
          } catch (err) {
            log.error(`Error handling /${cmd}: ${err.message}`);
            try { await sendLongMessage(token, chatId, `Error: ${err.message}`); } catch (_) {}
          }
        } else {
          await sendLongMessage(token, chatId,
            `Unknown command: /${cmd}\n\nAvailable commands: /help, /status, /servers, /sessions, /agents, /models`);
        }
        continue;
      }

      // Non-command message ‚îÄ process in background
      const st = getState(serverBase);
      if (st.busy) {
        await sendLongMessage(token, chatId, '‚è≥ Server is busy processing a previous message. Please wait for it to finish, or use /cancel to cancel it.');
        continue;
      }
      st.busy = true;
      const myTaskId = ++st.taskId;
      log.debug(`  ‚Üí started background processing (task ${myTaskId})`);
      processMessageAsync(chatId, replyContext + text, serverBase, !!st.activeSessionId, st.activeSessionId, myTaskId, replyTo);
    }
  }
}

process.on('SIGINT', () => {
  log.info('tgagentp stopped.');
  process.exit(0);
});

main().catch((err) => {
  console.error('Error:', err.message);
  process.exit(1);
});
