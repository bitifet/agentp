#!/usr/bin/env node

const http = require('http');
const fs = require('fs');
const readline = require('readline');
const { version } = require('../package.json');
const {
  sendToSession,
  listSessions,
  createSession,
} = require('../lib/opencode');

const TGAGENTP_PORT_FILE = '/tmp/tgagentp-port';

function notifyAgentpGateway(port, server, text) {
  return new Promise((resolve, reject) => {
    const body = JSON.stringify({ text, server });
    const options = {
      hostname: '127.0.0.1',
      port,
      path: '/send',
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Content-Length': Buffer.byteLength(body),
      },
    };
    const password = process.env.OPENCODE_SERVER_PASSWORD;
    if (password) {
      const username = process.env.OPENCODE_SERVER_USERNAME || 'opencode';
      options.headers['Authorization'] = 'Basic ' +
        Buffer.from(`${username}:${password}`).toString('base64');
    }
    const req = http.request(options, (res) => {
      let data = '';
      res.on('data', (chunk) => { data += chunk; });
      res.on('end', () => {
        if (res.statusCode === 200) {
          try {
            const result = JSON.parse(data);
            resolve(result.buffered || []);
          } catch {
            resolve([]);
          }
        } else {
          reject(new Error(`status ${res.statusCode}: ${data}`));
        }
      });
    });
    req.setTimeout(5000, () => {
      req.destroy();
      reject(new Error('Connection timed out'));
    });
    req.on('error', reject);
    req.write(body);
    req.end();
  });
}

async function readAllStdin() {
  let text = '';
  const rl = readline.createInterface({ input: process.stdin });
  for await (const line of rl) {
    text += line + '\n';
  }
  rl.close();
  return text;
}

const HUMAN_ROW = '👤: —————————————————\n'
const AGENT_ROW = '🤖: —————————————————\n'
const FINAL_ROW = '    —————————————————\n';

async function main() {
  let serverBase = 'http://localhost:4096';
  let qaMode = false;
  let flushMode = false;
  // tgMode: false = disabled, 'auto' = auto-detect, true = explicit --tg
  let tgMode = null;

  const args = process.argv.slice(2);
  for (let i = 0; i < args.length; i++) {
    if (args[i] === '--version') {
      console.log(version);
      process.exit(0);
    } else if (args[i] === '--help') {
      console.error('Usage: agentp [options] [url]');
      console.error('');
      console.error('Pipe prompt text to an OpenCode session and get the assistant response on stdout.');
      console.error('');
      console.error('Options:');
      console.error('  --version  Show version');
      console.error('  --qa       Print the original prompt and answer with labels (useful as a filter)');
      console.error('  --tg       Forward the answer to Telegram via agentp gateway (error if unavailable)');
      console.error('  --no-tg    Do not forward to Telegram');
      console.error('  --flush    Flush tgagentp\'s recorded buffer without prepending it to output');
      console.error('  --help     Show this help message');
      console.error('');
      console.error('By default, --qa auto-detects tgagentp; standalone mode implies --no-tg.');
      console.error('--tg: error if tgagentp is unavailable; auto mode: silently degrade.');
      console.error('');
      console.error('Arguments:');
      console.error('  url        OpenCode server URL or port number (default: 4096)');
      console.error('             Examples: 4096, http://localhost:4096, http://192.168.1.50:4096');
      console.error('');
      console.error('See also: tgagentp -- Telegram bridge (tgagentp --help), ocmux -- manage OpenCode tmux sessions (ocmux --help)');
      console.error('');
      console.error('Examples:');
      console.error('  printf "Summarize this file" | agentp');
      console.error('  cat prompt.txt | agentp 4096');
      console.error('  # Vim/Neovim filter, preserving prompt + answer:');
      console.error("  :'<,'>!agentp --qa");
      process.exit(0);
    } else if (args[i] === '--qa') {
      qaMode = true;
    } else if (args[i] === '--flush') {
      flushMode = true;
    } else if (args[i] === '--tg') {
      tgMode = true;
    } else if (args[i] === '--no-tg') {
      tgMode = false;
    } else if (args[i].includes('://')) {
      serverBase = args[i].replace(/\/+$/, '');
    } else if (/^\d+$/.test(args[i])) {
      serverBase = 'http://localhost:' + args[i];
    }
  }

  // Resolve default: --qa → auto-detect, standalone → disabled
  if (tgMode === null) {
    tgMode = qaMode ? 'auto' : false;
  }

  // Pre-send: probe tgagentp gateway if enabled
  let tgPort = null;
  if (tgMode) {
    try {
      tgPort = fs.readFileSync(TGAGENTP_PORT_FILE, 'utf8').trim();
      if (!tgPort || !/^\d+$/.test(tgPort)) tgPort = null;
    } catch {
      tgPort = null;
    }
    if (!tgPort && tgMode === true) {
      console.error('Error: tgagentp gateway not found. Is tgagentp running?');
      process.exit(1);
    }
    // auto mode: tgPort stays null → silently skip tgagentp
  }

  const promptText = await readAllStdin();

  // Find most recent session or create one
  let sessions;
  try {
    sessions = await listSessions(serverBase);
  } catch (err) {
    console.error('Error connecting to server:', err.message);
    process.exit(1);
  }

  let sessionId = null;
  if (sessions && sessions.length > 0) {
    const sorted = sessions
      .filter(s => s.time && s.time.updated)
      .sort((a, b) => b.time.updated - a.time.updated);
    if (sorted.length > 0) sessionId = sorted[0].id;
  }

  if (!sessionId) {
    try {
      const session = await createSession(serverBase, 'agentp');
      sessionId = session.id;
    } catch (err) {
      console.error('Error creating session:', err.message);
      process.exit(1);
    }
  }

  let answer;
  try {
    answer = await sendToSession(serverBase, sessionId, promptText);
  } catch (err) {
    console.error('Error sending prompt:', err.message);
    process.exit(1);
  }

  // Build the message to send to Telegram (QA pair with rulers)
  let tgMessage = answer;
  if (qaMode) {
    tgMessage = HUMAN_ROW + promptText + AGENT_ROW + answer;
    if (!answer.endsWith('\n')) tgMessage += '\n';
    tgMessage += FINAL_ROW;
  }

  // Post-send: notify tgagentp, get recorded context back
  let buffered = [];
  let tgError = null;
  if (tgPort) {
    try {
      buffered = await notifyAgentpGateway(tgPort, serverBase, tgMessage);
    } catch (err) {
      tgError = err;
    }
  }

  // Build stdout output (prepend recorded context if any, unless --flush)
  if (qaMode) {
    if (!flushMode && buffered.length > 0) {
      for (const msg of buffered) {
        const row = msg.role === 'user' ? HUMAN_ROW : AGENT_ROW;
        process.stdout.write(row + msg.text + '\n');
      }
    }
    process.stdout.write(tgMessage);
  } else {
    process.stdout.write(tgMessage);
    if (!tgMessage.endsWith('\n')) process.stdout.write('\n');
  }

  // Warnings at the end (stderr)
  if (tgError && tgMode === true) {
    process.stderr.write('\n');
    process.stderr.write(`⚠️  Telegram notification failed: ${tgError.message}\n`);
  }
  if (!process.env.OPENCODE_SERVER_PASSWORD) {
    process.stderr.write('\n');
    process.stderr.write('🔓 ⚠️  Server is not password-protected! Set OPENCODE_SERVER_PASSWORD for better security.\n');
  }
}

main().catch((err) => {
  console.error('Error:', err.message);
  process.exit(1);
});
