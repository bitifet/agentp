#!/usr/bin/env node

const http = require('http');
const fs = require('fs');
const readline = require('readline');
const child_process = require('child_process');
const { version } = require('../package.json');
const {
  sendToSession,
  listSessions,
  createSession,
  getSession,
  selectSession,
} = require('../lib/opencode');

const TGAGENTP_PORT_FILE = '/tmp/tgagentp-port';

function notifyAgentpGateway(port, server, text) {
  return new Promise((resolve, reject) => {
    const body = JSON.stringify({ text, server });
    const options = {
      hostname: '127.0.0.1',
      port,
      path: '/send',
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Content-Length': Buffer.byteLength(body),
      },
    };
    const password = process.env.OPENCODE_SERVER_PASSWORD;
    if (password) {
      const username = process.env.OPENCODE_SERVER_USERNAME || 'opencode';
      options.headers['Authorization'] = 'Basic ' +
        Buffer.from(`${username}:${password}`).toString('base64');
    }
    const req = http.request(options, (res) => {
      let data = '';
      res.on('data', (chunk) => { data += chunk; });
      res.on('end', () => {
        if (res.statusCode === 200) {
          try {
            const result = JSON.parse(data);
            resolve(result.buffered || []);
          } catch {
            resolve([]);
          }
        } else {
          reject(new Error(`status ${res.statusCode}: ${data}`));
        }
      });
    });
    req.setTimeout(5000, () => {
      req.destroy();
      reject(new Error('Connection timed out'));
    });
    req.on('error', reject);
    req.write(body);
    req.end();
  });
}

async function readAllStdin() {
  let text = '';
  const rl = readline.createInterface({ input: process.stdin });
  for await (const line of rl) {
    text += line + '\n';
  }
  rl.close();
  return text;
}

const HUMAN_ROW = '👤: —————————————————\n'
const AGENT_ROW = '🤖: —————————————————\n'
const FINAL_ROW = '    —————————————————\n';

async function main() {
  let serverBase = 'http://localhost:4096';
  let qaMode = false;
  let flushMode = false;
  let sessionName = null;
  let newSession = false;
  // tgMode: false = disabled, 'auto' = auto-detect, true = explicit --tg
  let tgMode = null;

  const args = process.argv.slice(2);
  for (let i = 0; i < args.length; i++) {
    if (args[i] === '--version') {
      console.log(version);
      process.exit(0);
    } else if (args[i] === '--help') {
      console.error('Usage: agentp [options] [url]');
      console.error('');
      console.error('Pipe prompt text to an OpenCode session and get the assistant response on stdout.');
      console.error('');
      console.error('Options:');
      console.error('  --version   Show version');
      console.error('  --qa        Print the original prompt and answer with labels (useful as a filter)');
      console.error('  --tg        Forward the answer to Telegram via agentp gateway (error if unavailable)');
      console.error('  --no-tg     Do not forward to Telegram');
      console.error('  --flush     Flush tgagentp\'s recorded buffer without prepending it to output');
      console.error('  --getLast   Retrieve last N assistant answers (or QA pairs with --qa) from session history');
      console.error('  --session   Target a specific session by name (creates it if not found with --new)');
      console.error('  --new       Create a new session with the given title (requires --session)');
      console.error('  --help      Show this help message');
      console.error('');
      console.error('By default, --qa auto-detects tgagentp; standalone mode implies --no-tg.');
      console.error('--tg: error if tgagentp is unavailable; auto mode: silently degrade.');
      console.error('');
      console.error('When --qa is combined with --getLast, the output includes full QA pairs');
      console.error('(user prompt + assistant answer) with rulers, matching the recorded');
      console.error('context replay format. Without --qa, only the assistant answers are shown.');
      console.error('');
      console.error('--flush clears the tgagentp recorded buffer and also prevents the prepended');
      console.error('context from appearing in --qa output. Use it when you want fresh context.');
      console.error('');
      console.error('--session <name> targets a specific session by exact or partial name match.');
      console.error('If the session does not exist, agentp errors (use --new to create it).');
      console.error('--new creates a new session with the given title (does not match existing sessions).');
      console.error('');
      console.error('Arguments:');
      console.error('  url        OpenCode server URL or port number (default: 4096)');
      console.error('             Examples: 4096, http://localhost:4096, http://192.168.1.50:4096');
      console.error('             Use `ocmux` (with no args) to get the URL of the current project\'s server.');
      console.error('');
      console.error('See also: tgagentp -- Telegram bridge (tgagentp --help), ocmux -- manage OpenCode tmux sessions (ocmux --help)');
      console.error('');
      console.error('Examples:');
      console.error('  printf "Summarize this file" | agentp');
      console.error('  cat prompt.txt | agentp $(ocmux)            # talk to current project\'s server');
      console.error('  cat prompt.txt | agentp --session "My Task" $(ocmux)');
      console.error('  cat prompt.txt | agentp --session "New Task" --new $(ocmux)');
      console.error('  # Vim/Neovim filter, preserving prompt + answer:');
      console.error("  :'<,'>!agentp --qa $(ocmux)");
      console.error('  # Retrieve last 3 assistant answers:');
      console.error('  agentp --getLast 3');
      console.error('  agentp --getLast 3 --qa                     # full QA pairs with rulers');
      console.error('  agentp --getLast 1 4096');
      process.exit(0);
    } else if (args[i] === '--qa') {
      qaMode = true;
    } else if (args[i] === '--flush') {
      flushMode = true;
    } else if (args[i] === '--session') {
      i++;
      sessionName = args[i];
      if (!sessionName) {
        console.error('Error: --session requires a session name');
        process.exit(1);
      }
    } else if (args[i] === '--new') {
      newSession = true;
    } else if (args[i] === '--getLast') {
      i++;
      const nStr = args[i];
      if (!nStr || !/^\d+$/.test(nStr)) {
        console.error('Error: --getLast requires a number (e.g. --getLast 5)');
        process.exit(1);
      }
      const n = parseInt(nStr, 10);
      try {
        const sessions = await listSessions(serverBase);
        if (!sessions || sessions.length === 0) {
          console.error('No sessions found.');
          process.exit(1);
        }
        const sorted = sessions
          .filter(s => s.time && (s.time.updated || s.time.created))
          .sort((a, b) => {
            const aTime = (a.time && a.time.updated) || (a.time && a.time.created) || 0;
            const bTime = (b.time && b.time.updated) || (b.time && b.time.created) || 0;
            return bTime - aTime;
          });
        const sessionId = sorted[0].id;

        function buildPairsFromMessages(messages) {
          const pairs = [];
          let cur = null;
          for (const raw of messages) {
            // Normalize: export gives {role, parts: [{type, text}]}, SQLite gives {role, text}
            const m = raw.parts ? raw : { role: raw.role, parts: [{ type: 'text', text: raw.text }] };
            const role = m.role;
            const text = (m.parts || []).filter(p => p.type === 'text').map(p => p.text).join('').trim();
            if (!text) continue;
            if (role === 'user') {
              if (cur) pairs.push(cur);
              cur = { prompt: text, answer: '' };
            } else if (role === 'assistant' && cur) {
              if (cur.answer) cur.answer += '\n';
              cur.answer += text;
            }
          }
          // Don't push incomplete pair (no answer yet)
          return pairs;
        }

        function formatPairs(pairs) {
          return pairs.map(p =>
            HUMAN_ROW + p.prompt + '\n' + AGENT_ROW + p.answer + '\n' + FINAL_ROW
          ).join('\n');
        }

        const formatAsQa = qaMode || args.includes('--qa');
        function extractAnswers(pairs) {
          return pairs.map(p => p.answer);
        }
        let output = '';
        try {
          const raw = child_process.execFileSync('opencode', ['export', sessionId], { encoding: 'utf8', maxBuffer: 50 * 1024 * 1024 });
          const jsonStart = raw.indexOf('{');
          const body = jsonStart >= 0 ? raw.slice(jsonStart) : raw;
          const exportData = JSON.parse(body);
          const messages = exportData.messages || [];
          const pairs = buildPairsFromMessages(messages);
          const lastN = pairs.slice(-n);
          output = formatAsQa ? formatPairs(lastN) : extractAnswers(lastN).join('\n');
        } catch {
          // export JSON is malformed (opencode bug);
          // fall back to SQLite
          const home = process.env.HOME || process.env.USERPROFILE || '';
          const dbCandidates = [
            `${home}/.local/share/opencode/opencode.db`,
            `${home}/Library/Application Support/opencode/opencode.db`,
            `${home}/.opencode/opencode.db`,
          ];
          let dbPath = null;
          for (const p of dbCandidates) {
            try { fs.accessSync(p); dbPath = p; break; } catch {}
          }
          if (dbPath) {
            const sql = `SELECT m.data->>'role' as role, group_concat(p.data->>'text', '') as text FROM message m JOIN part p ON p.message_id = m.id WHERE m.session_id = '${sessionId.replace(/'/g, "''")}' AND p.data->>'type' = 'text' AND m.data->>'role' IN ('user','assistant') GROUP BY m.id ORDER BY m.time_created ASC`;
            const out = child_process.execFileSync('sqlite3', ['-json', dbPath, sql], { encoding: 'utf8', maxBuffer: 50 * 1024 * 1024 });
            const messages = JSON.parse(out);
            const pairs = buildPairsFromMessages(messages);
            const lastN = pairs.slice(-n);
            output = formatAsQa ? formatPairs(lastN) : extractAnswers(lastN).join('\n');
          }
        }
        if (!output) {
          console.error(formatAsQa ? 'No complete prompt-answer pairs found in session history.' : 'No assistant answers found in session history.');
          process.exit(1);
        }
        process.stdout.write(output);
        if (!output.endsWith('\n')) process.stdout.write('\n');
      } catch (err) {
        console.error('Error retrieving session history:', err.message);
        process.exit(1);
      }
      return;
    } else if (args[i] === '--tg') {
      tgMode = true;
    } else if (args[i] === '--no-tg') {
      tgMode = false;
    } else if (args[i].includes('://')) {
      serverBase = args[i].replace(/\/+$/, '');
    } else if (/^\d+$/.test(args[i])) {
      serverBase = 'http://localhost:' + args[i];
    } else if (args[i].startsWith('--')) {
      console.error(`Error: unknown option '${args[i]}'`);
      console.error(`Usage: agentp [options] [url]`);
      console.error(`Try 'agentp --help' for more information.`);
      process.exit(1);
    } else {
      console.error(`Error: unexpected argument '${args[i]}'`);
      process.exit(1);
    }
  }

  // Resolve default: --qa → auto-detect, standalone → disabled
  if (tgMode === null) {
    tgMode = qaMode ? 'auto' : false;
  }

  // Pre-send: probe tgagentp gateway if enabled
  let tgPort = null;
  if (tgMode) {
    try {
      tgPort = fs.readFileSync(TGAGENTP_PORT_FILE, 'utf8').trim();
      if (!tgPort || !/^\d+$/.test(tgPort)) tgPort = null;
    } catch {
      tgPort = null;
    }
    if (!tgPort && tgMode === true) {
      console.error('Error: tgagentp gateway not found. Is tgagentp running?');
      process.exit(1);
    }
    // auto mode: tgPort stays null → silently skip tgagentp
  }

  const promptText = await readAllStdin();

  // Find most recent session or create one
  let sessions;
  try {
    sessions = await listSessions(serverBase);
  } catch (err) {
    console.error('Error connecting to server:', err.message);
    process.exit(1);
  }

  let sessionId = null;

  if (sessionName) {
    // Find session by name
    const matches = sessions.filter(s => {
      const title = s.title || s.slug || s.id;
      return title.toLowerCase() === sessionName.toLowerCase();
    });
    if (matches.length === 0) {
      // Try partial match
      const partial = sessions.filter(s => {
        const title = s.title || s.slug || s.id;
        return title.toLowerCase().includes(sessionName.toLowerCase());
      });
      if (partial.length === 1) {
        sessionId = partial[0].id;
      } else if (partial.length > 1) {
        console.error(`Error: multiple sessions match "${sessionName}":`);
        partial.forEach(s => console.error(`  - ${s.title || s.slug || s.id}`));
        process.exit(1);
      } else if (newSession) {
        // Create new session
        try {
          const session = await createSession(serverBase, sessionName);
          sessionId = session.id;
          await selectSession(serverBase, sessionId);
        } catch (err) {
          console.error('Error creating session:', err.message);
          process.exit(1);
        }
      } else {
        console.error(`Error: no session found matching "${sessionName}"`);
        console.error('Use --new to create a new session with this name');
        process.exit(1);
      }
    } else {
      sessionId = matches[0].id;
    }
  } else if (sessions && sessions.length > 0) {
    const sorted = sessions
      .filter(s => s.time && (s.time.updated || s.time.created))
      .sort((a, b) => {
        const aTime = (a.time && a.time.updated) || (a.time && a.time.created) || 0;
        const bTime = (b.time && b.time.updated) || (b.time && b.time.created) || 0;
        return bTime - aTime;
      });
    if (sorted.length > 0) sessionId = sorted[0].id;
  }

  if (!sessionId) {
    try {
      const session = await createSession(serverBase, 'agentp');
      sessionId = session.id;
    } catch (err) {
      console.error('Error creating session:', err.message);
      process.exit(1);
    }
  }

  let answer;
  try {
    answer = await sendToSession(serverBase, sessionId, promptText);
  } catch (err) {
    console.error('Error sending prompt:', err.message);
    process.exit(1);
  }

  // Build the message to send to Telegram (QA pair with rulers)
  let tgMessage = answer;
  if (qaMode) {
    tgMessage = HUMAN_ROW + promptText + AGENT_ROW + answer;
    if (!answer.endsWith('\n')) tgMessage += '\n';
    tgMessage += FINAL_ROW;
  }

  // Post-send: notify tgagentp, get recorded context back
  let buffered = [];
  let tgError = null;
  if (tgPort) {
    try {
      buffered = await notifyAgentpGateway(tgPort, serverBase, tgMessage);
    } catch (err) {
      tgError = err;
    }
  }

  // Build stdout output (prepend recorded context if any, unless --flush)
  if (qaMode) {
    if (!flushMode && buffered.length > 0) {
      for (const msg of buffered) {
        const row = msg.role === 'user' ? HUMAN_ROW : AGENT_ROW;
        process.stdout.write(row + msg.text + '\n');
      }
    }
    process.stdout.write(tgMessage);
  } else {
    process.stdout.write(tgMessage);
    if (!tgMessage.endsWith('\n')) process.stdout.write('\n');
  }

  // Warnings at the end (stderr)
  if (tgError && tgMode === true) {
    process.stderr.write('\n');
    process.stderr.write(`⚠️  Telegram notification failed: ${tgError.message}\n`);
  }
  if (!process.env.OPENCODE_SERVER_PASSWORD) {
    process.stderr.write('\n');
    process.stderr.write('🔓 ⚠️  Server is not password-protected! Set OPENCODE_SERVER_PASSWORD for better security.\n');
  }
}

if (require.main === module) {
  main().catch((err) => {
    console.error('Error:', err.message);
    process.exit(1);
  });
}

module.exports = { main, notifyAgentpGateway, readAllStdin };

