#!/usr/bin/env node

const http = require('http');
const { URL } = require('url');
const { version } = require('../package.json');

function getAuthHeaders() {
  const password = process.env.OPENCODE_SERVER_PASSWORD;
  if (!password) return {};
  const username = process.env.OPENCODE_SERVER_USERNAME || 'opencode';
  const encoded = Buffer.from(`${username}:${password}`).toString('base64');
  return { 'Authorization': `Basic ${encoded}` };
}

function makeRequest(options, data) {
  return new Promise((resolve, reject) => {
    const req = http.request(options, (res) => {
      let body = '';
      res.on('data', (chunk) => { body += chunk; });
      res.on('end', () => {
        if (res.statusCode === 401) {
          reject(new Error('OpenCode server authentication failed. Set OPENCODE_SERVER_PASSWORD to match the server password.'));
        } else {
          resolve({ status: res.statusCode, body });
        }
      });
    });
    req.on('error', reject);
    if (data) req.write(data);
    req.end();
  });
}

function buildJsonRequest(url, method, body) {
  const parsed = new URL(url);
  return {
    hostname: parsed.hostname,
    port: parsed.port,
    path: parsed.pathname,
    method: method,
    headers: {
      'Content-Type': 'application/json',
      'Content-Length': Buffer.byteLength(body),
      ...getAuthHeaders()
    }
  };
}

async function clearPrompt(server) {
  const url = `${server}/tui/clear-prompt`;
  await makeRequest(buildJsonRequest(url, 'POST', '{}'), '{}');
}

async function appendPrompt(server, text) {
  const url = `${server}/tui/append-prompt`;
  const body = JSON.stringify({ text });
  await makeRequest(buildJsonRequest(url, 'POST', body), body);
}

async function submitPrompt(server) {
  const url = `${server}/tui/submit-prompt`;
  await makeRequest(buildJsonRequest(url, 'POST', '{}'), '{}');
}

async function sendPrompt(server) {
  let promptText = '';

  await clearPrompt(server);

  const readline = require('readline');
  const rl = readline.createInterface({ input: process.stdin });

  for await (const line of rl) {
    const promptLine = line + '\n';
    promptText += promptLine;
    await appendPrompt(server, promptLine);
  }

  rl.close();
  await submitPrompt(server);
  return promptText;
}

const HUMAN_ROW = '👤: ￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣\n'
const AGENT_ROW = '🤖: ￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣\n'
const FINAL_ROW = '￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣\n';

function listenForFinalAnswer(server, showFinalRow) {
  return new Promise((resolve, reject) => {
    const url = `${server}/event`;
    const parsed = new URL(url);

    const req = http.request({
      hostname: parsed.hostname,
      port: parsed.port,
      path: parsed.pathname,
      method: 'GET',
      headers: { 'Accept': 'text/event-stream', ...getAuthHeaders() }
    }, (res) => {
      if (res.statusCode === 401) {
        res.resume();
        reject(new Error('OpenCode server authentication failed. Set OPENCODE_SERVER_PASSWORD to match the server password.'));
        return;
      }
      let buffer = '';
      const userMessageIDs = new Set();

      res.on('data', (chunk) => {
        buffer += chunk.toString();

        // Split by double newline (SSE event separator)
        while (buffer.includes('\n\n')) {
          const eventEnd = buffer.indexOf('\n\n');
          const eventData = buffer.slice(0, eventEnd);
          buffer = buffer.slice(eventEnd + 2);

          // Extract data lines
          const lines = eventData.split('\n');

          let jsonStr = '';

          for (const line of lines) {
            if (line.startsWith('data: ')) {
              jsonStr += line.slice(6);
            }
          }

          if (!jsonStr.trim()) continue;

          try {
            const event = JSON.parse(jsonStr);

            // Track user message IDs
            if (event.type === 'message.updated' && event.properties?.info?.role === 'user') {
              userMessageIDs.add(event.properties.info.id);
            }

            // Check for session.idle to detect completion
            if (event.type === 'session.idle') {
              process.stdout.write('\n');
              if (showFinalRow) {
                process.stdout.write(`${FINAL_ROW}`);
              }
              req.destroy();
              res.destroy();
              resolve();
              return;
            }

            const part = event.properties?.part;
            if (!part) continue;

            // Filter out user input by checking messageID
            if (part.messageID && userMessageIDs.has(part.messageID)) {
              continue;
            }

            if (part.type === 'text' && part.text != null && part.text !== '') {
              process.stdout.write(part.text);
            }
          } catch (e) {
          }
        }
      });

      res.on('end', () => {
        resolve();
      });
    });

    req.on('error', reject);
    req.end();
  });
}

async function main() {
  let serverBase = 'http://localhost:4096';
  let qaMode = false;

  const args = process.argv.slice(2);
  for (let i = 0; i < args.length; i++) {
    if (args[i] === '--version') {
      console.log(version);
      process.exit(0);
    } else if (args[i] === '--help') {
      console.error('Usage: agentp [options] [url]');
      console.error('');
      console.error('Pipe prompt text to an OpenCode TUI session and stream the assistant response to stdout.');
      console.error('');
      console.error('Options:');
      console.error('  --version  Show version');
      console.error('  --qa       Print the original prompt and answer with labels (useful as a filter)');
      console.error('  --help     Show this help message');
      console.error('');
      console.error('Arguments:');
      console.error('  url        OpenCode TUI server URL or port number (default: 4096)');
      console.error('             Examples: 4096, http://localhost:4096, http://192.168.1.50:4096');
      console.error('');
      console.error('See also: ocmux -- manage OpenCode tmux sessions (ocmux --help)');
      console.error('');
      console.error('Examples:');
      console.error('  printf "Summarize this file" | agentp');
      console.error('  cat prompt.txt | agentp 4096');
      console.error('  # Vim/Neovim filter, preserving prompt + answer:');
      console.error("  :'<,'>!agentp --qa");
      process.exit(0);
    } else if (args[i] === '--qa') {
      qaMode = true;
    } else if (args[i].includes('://')) {
      serverBase = args[i].replace(/\/+$/, '');
    } else if (/^\d+$/.test(args[i])) {
      serverBase = 'http://localhost:' + args[i];
    }
  }

  const promptText = await sendPrompt(serverBase);

  if (qaMode) {
    process.stdout.write(HUMAN_ROW);
    process.stdout.write(promptText);
    process.stdout.write(AGENT_ROW);
  }

  await listenForFinalAnswer(serverBase, qaMode);
}

main().catch((err) => {
  console.error('Error:', err.message);
  process.exit(1);
});
